---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

/* ─── Dog Data ─── */
const dogs = [
  { id: 6095,  inscription: 'f3e1174ba880735bf1fe0f07d904a23b7e164edf224203d9b8f6aacc6f207870i0', rarity: 5093  },
  { id: 4821,  inscription: 'f51ba6025ac30c70fa5d47dcfbcb51e3f03add69f2a21da0de5bd93fdbf7f9b5i0', rarity: 114   },
  { id: 9500,  inscription: '037e760b9cad620a2401342850be829cc9558cd524f55ffe5d2c182fac7ed885i0', rarity: 8368  },
  { id: 2422,  inscription: '664cdd0ac22d72f9f5cf3f375277e17f44254088f20fcaea34b328868d5e24a1i0', rarity: 6127  },
  { id: 3738,  inscription: '02ffb945fbbf8abce195b155ec9c27a66d2ad47b43e37ac3a52714a75e16989di0', rarity: 5788  },
  { id: 9640,  inscription: '067c20d7ffd0d058c59a605ccc3ba7830d9313e41c0afed9cfbf974c088d46ebi0', rarity: 3503  },
  { id: 1107,  inscription: 'da3dce8f4c904dd4908627a0a278735b075428007064f1f62320e63d88543b8ei0', rarity: 61    },
  { id: 1294,  inscription: 'b150b7c436b88dd421d9b6caeac0d0b4863001e0b9c19b7a717d915ff59328dci0', rarity: 9762  },
  { id: 5530,  inscription: '0219c115a9077ad55a648283e29ea4d047ca99efb5069c4b0c35b8542906c1afi0', rarity: 2     },
  { id: 1087,  inscription: '062627e176893da6f30b2d259c3cff3123e5de6826528ceb7651b17cdd3957afi0', rarity: 5455  },
];
---

<Layout
  title="Collection — Leah Bluewater"
  description="Leah Bluewater's Doginal Dogs collection. Pixel-art dogs inscribed on the Dogecoin blockchain."
>
  <Nav slot="nav" />

  {/* ─── Video Background ─── */}
  <div class="video-bg" aria-hidden="true">
    <video
      src="/collection_hero.mp4"
      autoplay
      muted
      loop
      playsinline
      class="video-bg__film"
    ></video>
    <div class="video-bg__scrim"></div>
  </div>

  <section class="section" aria-labelledby="collection-heading">
    <div class="container">

      {/* ─── Header ─── */}
      <header class="collection-header">
        <h2 class="collection-heading" id="collection-heading">Collection</h2>
        <p class="collection-sub mono-label">
          Pixel-art dogs inscribed on the Dogecoin blockchain.&nbsp;
          <a
            href="https://market.doginaldogs.com"
            target="_blank"
            rel="noopener noreferrer"
            class="link-accent"
          >market.doginaldogs.com ↗</a>
        </p>
      </header>

      {/* ─── Grid ─── */}
      <ul class="dog-grid" role="list">
        {dogs.map((dog, i) => (
          <li
            class="dog-card"
            style={`--delay:${i*60}ms;--td:-${(i*0.28).toFixed(2)}s;--tdur:${(2.2+(i%3)*0.15).toFixed(2)}s`}
            aria-label={`Doginal Dog #${dog.id}`}
          >
            {/* Travelling border */}
            <svg class="card-svg" aria-hidden="true" focusable="false">
              <rect class="card-trail" pathLength="1" />
              <rect class="card-dot"   pathLength="1" />
            </svg>
            {/* Image */}
            <a
              href={`https://market.doginaldogs.com/inscription/${dog.inscription}`}
              target="_blank"
              rel="noopener noreferrer"
              class="dog-img-link"
              tabindex="-1"
              aria-hidden="true"
            >
              <div class="dog-img-wrap">
                <img
                  src={`/dogs/${dog.id}.png`}
                  alt={`Doginal Dog #${dog.id}`}
                  width="400"
                  height="400"
                  class="dog-img"
                  loading={i < 4 ? 'eager' : 'lazy'}
                  decoding="async"
                  data-dog-id={dog.id}
                />
              </div>
            </a>

            {/* Color strip */}
            <div
              class="dog-palette"
              data-palette-id={dog.id}
              aria-hidden="true"
            >
              {/* swatches injected by JS */}
            </div>

            {/* Footer: ID + rarity + market link */}
            <div class="dog-foot">
              <div class="dog-meta">
                <span class="dog-id">#{dog.id}</span>
                <span class="dog-rarity mono-label">rank&nbsp;#{dog.rarity.toLocaleString()}</span>
              </div>
              <a
                href={`https://market.doginaldogs.com/inscription/${dog.inscription}`}
                target="_blank"
                rel="noopener noreferrer"
                class="dog-market-link mono-label"
                aria-label={`View Doginal Dog #${dog.id} on market`}
              >View ↗</a>
            </div>
          </li>
        ))}
      </ul>

    </div>
  </section>
</Layout>

{/* ─── Client-side palette extraction ─── */}
<script>
  function quantize(v: number, step = 24) {
    return Math.round(v / step) * step;
  }

  function extractPalette(img: HTMLImageElement, count = 8): string[] {
    const size = 64;
    const canvas = document.createElement('canvas');
    canvas.width = size;
    canvas.height = size;
    const ctx = canvas.getContext('2d')!;
    ctx.drawImage(img, 0, 0, size, size);

    const { data } = ctx.getImageData(0, 0, size, size);
    const freq = new Map<string, number>();

    for (let i = 0; i < data.length; i += 4) {
      const a = data[i + 3];
      if (a < 200) continue;                       // skip transparent
      const r = data[i], g = data[i + 1], b = data[i + 2];
      const lum = 0.299 * r + 0.587 * g + 0.114 * b;
      if (lum < 20 || lum > 242) continue;         // skip near-black / near-white
      const key = `${quantize(r)},${quantize(g)},${quantize(b)}`;
      freq.set(key, (freq.get(key) ?? 0) + 1);
    }

    return [...freq.entries()]
      .sort((a, b) => b[1] - a[1])
      .slice(0, count)
      .map(([k]) => {
        const [r, g, b] = k.split(',').map(Number);
        return `rgb(${r},${g},${b})`;
      });
  }

  function paintPalette(img: HTMLImageElement) {
    const id = img.dataset.dogId;
    if (!id) return;
    const strip = document.querySelector<HTMLElement>(`.dog-palette[data-palette-id="${id}"]`);
    if (!strip || strip.childElementCount > 0) return;

    try {
      const colors = extractPalette(img);
      if (!colors.length) return;
      colors.forEach(color => {
        const sw = document.createElement('span');
        sw.className = 'swatch';
        sw.style.background = color;
        strip.appendChild(sw);
      });
      strip.classList.add('is-ready');
    } catch {
      /* CORS blocked — strip stays hidden (graceful) */
    }
  }

  function initPalettes() {
    document.querySelectorAll<HTMLImageElement>('.dog-img').forEach(img => {
      if (img.complete && img.naturalWidth) paintPalette(img);
      else img.addEventListener('load', () => paintPalette(img), { once: true });
    });
  }

  /* Run on Astro View Transitions and hard loads */
  document.addEventListener('astro:page-load', initPalettes);
  if (document.readyState === 'complete') initPalettes();
  else window.addEventListener('load', initPalettes, { once: true });
</script>

<style is:global>
  /* Swatch elements are injected by JS — must be global */
  .dog-palette .swatch {
    flex: 1;
    display: block;
    height: 100%;
    min-width: 0;
    transition: transform 180ms cubic-bezier(0.16, 1, 0.3, 1);
    cursor: default;
  }

  .dog-palette .swatch:hover {
    transform: scaleY(1.4);
    z-index: 2;
    position: relative;
  }

  /* Entrance animation (JS-injected nodes need global too) */
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<style>
  /* ─── Video Background ─── */
  .video-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }

  .video-bg__film {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Dark tinted scrim so text stays legible — stays true to the water palette */
  .video-bg__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        rgba(0, 10, 20, 0.55) 0%,
        rgba(0, 20, 38, 0.45) 50%,
        rgba(0, 10, 20, 0.65) 100%
      );
  }

  /* ─── Section ─── */
  .section {
    min-height: 100vh;
    padding-block: calc(64px + 4rem) 5rem;   /* clear fixed nav */
  }

  .container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(1rem, 5vw, 3rem);
  }

  /* ─── Header ─── */
  .collection-header {
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .collection-heading {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0 0 0.5rem;
    /* subtle shimmer on the heading to echo water */
    background: linear-gradient(
      135deg,
      #ffffff 0%,
      #b3d9f0 45%,
      #ffffff 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .collection-sub {
    font-family: 'Space Mono', monospace;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .collection-sub .link-accent {
    color: #7ecef0;
    text-decoration: none;
    border-bottom: 1px solid rgba(126, 206, 240, 0.4);
    transition: color 150ms ease, border-color 150ms ease;
  }

  .collection-sub .link-accent:hover {
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.6);
  }

  /* ─── Grid: 4 col → 2 col → 1 col ─── */
  .dog-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  @media (max-width: 900px) {
    .dog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 420px) {
    .dog-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
  }

  /* ─── Dog Card ─── */
  /* ─── Travelling border SVG ─── */
  .card-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
    z-index: 1;
    border-radius: inherit;
  }

  /* Shared geometry — CSS SVG geometry properties */
  .card-trail,
  .card-dot {
    x: 1px;
    y: 1px;
    width: calc(100% - 2px);
    height: calc(100% - 2px);
    rx: 13px;
    fill: none;
    stroke-linecap: round;
  }

  /* Comet tail: short gold dash, blurred for glow */
  .card-trail {
    stroke: rgba(251, 191, 36, 0.55);
    stroke-width: 1.5;
    stroke-dasharray: 0.18 0.82;
    filter: blur(1px) drop-shadow(0 0 3px rgba(251,191,36,0.6));
    animation: card-travel var(--tdur, 2.2s) linear infinite;
    animation-delay: var(--td, 0s);
  }

  /* The dot: bright, tiny, sharp */
  .card-dot {
    stroke: #fbbf24;
    stroke-width: 2.5;
    stroke-dasharray: 0.016 0.984;
    filter: drop-shadow(0 0 4px #fbbf24);
    animation: card-travel var(--tdur, 2.2s) linear infinite;
    animation-delay: var(--td, 0s);
  }

  @keyframes card-travel {
    to { stroke-dashoffset: -1; }
  }

  /* ─── Dog Card ─── */
  .dog-card {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(14px) saturate(1.6);
    -webkit-backdrop-filter: blur(14px) saturate(1.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;

    /* Entrance */
    animation: fadeSlideUp 480ms cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: var(--delay, 0ms);

    transition:
      transform 250ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 250ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 250ms ease;
  }

  .dog-card:hover {
    transform: translateY(-4px) scale(1.015);
    box-shadow:
      0 20px 40px rgba(0, 0, 0, 0.35),
      0 0 0 1px rgba(126, 206, 240, 0.25);
    border-color: rgba(126, 206, 240, 0.35);
  }

  /* Shimmer sweep on hover */
  .dog-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255, 255, 255, 0.07) 50%,
      transparent 70%
    );
    transform: translateX(-100%);
    transition: transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    border-radius: inherit;
  }

  .dog-card:hover::before {
    transform: translateX(100%);
  }

  /* Card needs position for pseudo */
  .dog-card {
    position: relative;
  }

  /* ─── Image ─── */
  .dog-img-link {
    display: block;
    text-decoration: none;
    overflow: hidden;
  }

  .dog-img-wrap {
    aspect-ratio: 1;
    background: rgba(0, 0, 0, 0.25);
    overflow: hidden;
  }

  .dog-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    display: block;
    transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .dog-card:hover .dog-img {
    transform: scale(1.05);
  }

  /* ─── Palette Strip ─── */
  .dog-palette {
    display: flex;
    height: 6px;
    background: rgba(255, 255, 255, 0.06);
    overflow: hidden;
    /* Initially invisible until JS populates it */
    opacity: 0;
    transition: opacity 300ms ease;
  }

  .dog-palette.is-ready {
    opacity: 1;
  }

  /* ─── Footer ─── */
  .dog-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.65rem 0.85rem 0.75rem;
    gap: 0.5rem;
  }

  .dog-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .dog-id {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #ffffff;
    line-height: 1.1;
    white-space: nowrap;
  }

  .dog-rarity {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.45);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dog-market-link {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    color: #7ecef0;
    text-decoration: none;
    border: 1px solid rgba(126, 206, 240, 0.35);
    border-radius: 6px;
    padding: 0.28rem 0.55rem;
    white-space: nowrap;
    flex-shrink: 0;
    transition:
      color 150ms ease,
      background 150ms ease,
      border-color 150ms ease;
  }

  .dog-market-link:hover,
  .dog-market-link:focus-visible {
    color: #0a0a0a;
    background: #7ecef0;
    border-color: #7ecef0;
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .dog-card {
      animation: none;
    }
    .dog-card,
    .dog-card::before,
    .dog-img,
    .card-trail,
    .card-dot {
      animation: none;
      transition: none;
    }
  }
</style>
