    border-radius: var(--radius-sm, 8px);
    overflow: hidden;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dog-img-wrap--main {
    max-width: 400px;
    margin: 0 auto;
  }

  .dog-img-wrap--pair {
    max-width: 280px;
    margin: 0 auto;
  }

  .dog-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    transition: transform var(--dur-slow, 400ms) var(--ease-out);
  }

  .dog-card:hover .dog-img {
    transform: scale(1.02);
  }

  .dog-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .dog-details-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2) var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--clr-border, rgba(255,255,255,0.08));
  }

  .dog-title {
    font-size: var(--fs-xl, 1.5rem);
    font-weight: 700;
    margin: 0;
  }

  .dog-owner,
  .dog-trait-count {
    font-size: var(--fs-sm, 0.875rem);
  }

  .traits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }

  .traits-grid--compact {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
  }

  @media (max-width: 480px) {
    .traits-grid,
    .traits-grid--compact {
      grid-template-columns: 1fr;
    }
  }

  .trait-card {
    background: var(--clr-bg-surface, rgba(255,255,255,0.04));
    border: 1px solid var(--clr-border, rgba(255,255,255,0.06));
    border-radius: var(--radius-sm, 8px);
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .trait-card--compact {
    padding: var(--space-2);
  }

  .trait-label {
    font-size: var(--fs-xs, 0.75rem);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .trait-value {
    font-size: var(--fs-base, 1rem);
    font-weight: 600;
  }

  .rarity-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    background: var(--clr-bg-surface, rgba(255,255,255,0.04));
    border: 1px solid var(--clr-border, rgba(255,255,255,0.06));
    border-radius: var(--radius-sm, 8px);
  }

  .rarity-bar--compact {
    padding: var(--space-2) var(--space-3);
  }

  .rarity-value {
    font-size: var(--fs-lg, 1.125rem);
    font-weight: 700;
    color: var(--clr-accent, #f59e0b);
  }

  .color-strip {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .color-strip--compact {
    gap: var(--space-1);
  }

  .strip-label {
    font-size: var(--fs-xs, 0.75rem);
  }

  .strip-colors {
    display: flex;
    gap: 2px;
    height: 24px;
    border-radius: var(--radius-sm, 8px);
    overflow: hidden;
  }

  .color-swatch {
    flex: 1;
    height: 100%;
    min-width: 20px;
    transition: transform 0.2s ease;
  }

  .color-swatch:hover {
    transform: scaleY(1.3);
    z-index: 1;
  }

  .dog-btn {
    width: 100%;
    justify-content: center;
    padding-block: var(--space-3);
    font-size: var(--fs-sm, 0.875rem);
  }

  .dog-btn--compact {
    padding-block: var(--space-2);
    font-size: var(--fs-xs, 0.75rem);
  }

  .dog-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    margin-bottom: var(--space-6);
  }

  @media (max-width: 768px) {
    .dog-pair {
      grid-template-columns: 1fr;
    }
  }

  .dog-pair-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    padding: var(--space-4);
  }

  @media (max-width: 640px) {
    .dog-pair-layout {
      grid-template-columns: 1fr;
    }
  }

  .dog-bottom {
    display: flex;
    justify-content: center;
    margin-top: var(--space-4);
  }

  .dog-card--bottom {
    max-width: 600px;
    width: 100%;
  }

  .text-muted {
    color: var(--clr-text-muted);
  }
</style>
