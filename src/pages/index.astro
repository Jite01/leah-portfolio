---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Ticker from '../components/Ticker.astro';
import WaterCanvas from '../components/WaterCanvas.astro';
import kickoffData from '../data/kickoffs.json';

const { nextKickoff, archive } = kickoffData;
const targetIso = `${nextKickoff.date}T11:00:00+01:00`;
---

<Layout
  title="Leah Bluewater — Crypto & Finance Voice"
  description="Daily crypto commentary, The Kickoff X Space, and Doginal Dogs collector. 16K+ followers on X."
>
  <Nav slot="nav" />

  <section class="landing" aria-label="Introduction">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="landing-inner container">
      <div class="landing-identity">
        <div class="landing-copy">
          <h1 class="landing-name">
            Leah<br />
            <span class="name-line-2">
              <span class="name-blue">Blue</span><WaterCanvas />
            </span>
          </h1>
          <p class="landing-handle typewriter-handle" id="typewriter-handle"></p>
          <p class="landing-bio">
            Crypto &amp; finance voice. Daily markets. Host of The Kickoff.
            <span class="landing-followers mono-label">16K+ on X</span>
          </p>
        </div>
      </div>
    </div>
    <div class="ticker-slot">
      <Ticker />
    </div>
  </section>

  <section class="section" id="kickoff" aria-labelledby="kickoff-heading">
    <div class="container">
      <header class="section-header">
        <h2 class="section-heading" id="kickoff-heading">The Kickoff</h2>
        <p class="section-sub mono-label">Daily X Space · 10AM UTC · 5AM EST · 4AM CST</p>
      </header>

      <div
        class="next-card"
        aria-label="Next Kickoff details"
        id="next-card"
        data-target={targetIso}
        data-has-url={nextKickoff.url ? 'true' : 'false'}
      >
        <!-- ═══ Rotating metallic ring ═══ -->
        <div class="next-card-ring" aria-hidden="true">
          <div class="next-card-ring-halo"></div>
          <div class="next-card-ring-face"></div>
        </div>

        <!-- ═══ Premium metallic halo badge — orbits the card perimeter via RAF ═══ -->
        <div class="kickoff-badge" aria-hidden="true" id="kickoff-badge">
          <div class="kickoff-badge-halo"></div>
          <div class="kickoff-badge-halo kickoff-badge-halo--outer"></div>
          <div class="kickoff-badge-face">🏈</div>
        </div>

        <div class="next-card-meta">
          <span class="mono-label-bold text-accent">NEXT</span>
          <span class="mono-label">{nextKickoff.dayLabel}</span>
          <span class="mono-label">{nextKickoff.utc} · {nextKickoff.est} · {nextKickoff.cst}</span>
        </div>

        <div class="next-card-countdown mono-label" id="next-card-countdown" aria-live="polite">
          --:--:--
        </div>

        {nextKickoff.url ? (
          <a href={nextKickoff.url} target="_blank" rel="noopener noreferrer" class="btn btn-primary">Join Space</a>
        ) : (
          <span class="btn btn-ghost" aria-disabled="true">Waiting...</span>
        )}
      </div>

      <div class="kickoff-archive" aria-label="Kickoff archive">
        <h3 class="archive-label mono-label-bold">Archive</h3>
        <ul class="kickoff-list" role="list">
          {archive.map(ep => (
            <li class="kickoff-row">
              <span class="kickoff-date mono-label text-muted">{ep.date}</span>
              <span class="kickoff-title">{ep.title}</span>
              <span class="kickoff-dur mono-label text-muted">{ep.duration}</span>
              <span class="kickoff-summary mono-label text-muted">{ep.summary}</span>
            </li>
          ))}
        </ul>
      </div>

      <p class="placeholder-note mono-label text-muted">✦ AI episode summaries via lurky.ai</p>
    </div>
  </section>
</Layout>

<style>
  .landing {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url('https://i.imgur.com/3S4HfHp.png');
    background-size: cover;
    background-position: center center;
    opacity: 0.29;
    animation: hero-breathe 10s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes hero-breathe {
    0%,
    100% {
      opacity: 0.59;
    }
    50% {
      opacity: 0.99;
    }
  }

  .landing-inner,
  .ticker-slot {
    position: relative;
    z-index: 1;
  }

  .landing {
    position: relative;
    padding-top: var(--space-3);
    padding-bottom: 0;
    border-bottom: 1px solid var(--clr-border);
  }

  .landing-inner {
    padding-bottom: var(--space-6);
  }

  .landing-identity {
    display: flex;
    align-items: flex-start;
    gap: var(--space-6);
  }

  .landing-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .landing-name {
    font-family: var(--font-heading);
    font-weight: var(--fw-extrabold);
    font-size: var(--fs-4xl);
    line-height: 0.95;
    letter-spacing: -0.04em;
    animation: fade-in-up 0.6s var(--ease-out) both;
  }

  .name-line-2 {
    display: inline-flex;
    align-items: baseline;
    gap: 0;
  }

  .name-blue {
    color: var(--clr-text);
  }

  .typewriter-handle {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
    letter-spacing: 0.02em;
    min-height: 1.5em;
    animation: fade-in 0.6s var(--ease-out) 400ms both;
  }

  .landing-bio {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    animation: fade-in-up 0.6s var(--ease-out) 500ms both;
  }

  .landing-followers {
    color: var(--clr-accent);
    background: var(--clr-accent-wash);
    padding: 2px 8px;
    border-radius: 2px;
  }

  .ticker-slot {
    animation: fade-in 0.6s var(--ease-out) 600ms both;
  }

  .section-sub {
    color: var(--clr-text-muted);
    margin-top: var(--space-2);
  }

  /* ═══════════════════════════════════════════ NEXT CARD ═══════════════════════════════════════════ */
  .next-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    padding: var(--space-5) var(--space-6);
    padding-top: calc(var(--space-5) + 18px);
    border-radius: var(--radius-md);
    background: var(--clr-accent-wash);
    margin-bottom: var(--space-8);
    overflow: visible;
  }

  /* ── Rotating metallic ring (mask-free face-plate technique) ── */
  .next-card-ring {
    position: absolute;
    inset: -2px;
    border-radius: calc(var(--radius-md) + 2px);
    overflow: hidden;
    pointer-events: none;
    filter: drop-shadow(0 0 8px rgba(180,200,220,0.4)) drop-shadow(0 0 20px rgba(0,119,182,0.15));
    z-index: 0;
  }

  .next-card-ring-halo {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: conic-gradient(
      from 0deg,
      rgba(180,190,200,0.3),
      rgba(220,230,240,0.8),
      rgba(160,170,180,0.4),
      rgba(200,210,220,0.9),
      rgba(140,150,160,0.3),
      rgba(180,190,200,0.3)
    );
  }

  .next-card-ring-face {
    position: absolute;
    inset: 2px;
    border-radius: var(--radius-md);
    background: var(--clr-accent-wash);
    z-index: 1;
  }

  /* ═══════════════════════════════════════════ KICKOFF BADGE ═══════════════════════════════════════════ */
  .kickoff-badge {
    position: absolute;
    top: -24px;
    left: calc(50% - 24px);
    width: 48px;
    height: 48px;
    z-index: 10;
  }

  /* ── Inner ring (RAF-rotated) ── */
  .kickoff-badge-halo {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      rgba(70, 85, 100, 0.25),
      rgba(180, 198, 215, 0.80),
      rgba(235, 245, 255, 1.00),
      rgba(255, 255, 255, 1.00),
      rgba(200, 215, 228, 0.85),
      rgba(150, 168, 185, 0.60),
      rgba(100, 118, 135, 0.35),
      rgba(70, 85, 100, 0.25)
    );
  }

  /* ── Outer diffuse blue halo (RAF counter-rotated) ── */
  .kickoff-badge-halo--outer {
    inset: -5px;
    background: conic-gradient(
      from 180deg,
      rgba(60, 80, 110, 0.00),
      rgba(100, 150, 200, 0.45),
      rgba(180, 210, 240, 0.70),
      rgba(100, 150, 200, 0.45),
      rgba(60, 80, 110, 0.00)
    );
    filter: blur(1px);
  }

  /* ── Face plate: covers halo centre, emoji sits here ── */
  .kickoff-badge-face {
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    background: radial-gradient(circle at 38% 36%, rgba(28, 34, 42, 1) 0%, rgba(16, 20, 26, 1) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    line-height: 1;
    z-index: 2;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.12),
      inset 0 -1px 2px rgba(0, 0, 0, 0.55),
      0 0 12px rgba(140, 185, 230, 0.50),
      0 0 28px rgba(60, 130, 200, 0.25);
    user-select: none;
  }

  /* ─── card body ─── */
  .next-card-meta,
  .next-card-countdown,
  .next-card .btn {
    position: relative;
    z-index: 2;
  }

  .next-card-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex: 1;
    min-width: 180px;
  }

  .next-card-countdown {
    font-variant-numeric: tabular-nums;
    font-size: var(--fs-xl);
    font-weight: var(--fw-bold);
    color: var(--clr-accent);
    letter-spacing: 0.04em;
    min-width: 120px;
  }

  .archive-label {
    margin-bottom: var(--space-4);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--clr-text-faint);
  }

  .kickoff-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--clr-border);
  }

  .kickoff-row {
    display: grid;
    grid-template-columns: 110px 1fr 60px auto;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--clr-border);
    transition: background var(--dur-fast) var(--ease-out);
  }

  .kickoff-row:hover {
    background: var(--clr-bg-off);
    padding-inline: var(--space-3);
    border-radius: var(--radius-sm);
    margin-inline: calc(-1 * var(--space-3));
  }

  .kickoff-title {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    line-height: 1.4;
  }

  .kickoff-dur {
    text-align: right;
  }

  .kickoff-summary {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--clr-text-muted);
    line-height: 1.4;
    max-width: 260px;
  }

  .placeholder-note {
    margin-top: var(--space-6);
    padding: var(--space-4);
    border: 1px dashed var(--clr-border);
    border-radius: var(--radius-sm);
    text-align: center;
  }

  @media (max-width: 640px) {
    .landing-name {
      font-size: clamp(2.5rem, 12vw, var(--fs-3xl));
    }

    .kickoff-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto auto;
      gap: var(--space-2);
    }

    .kickoff-date {
      grid-column: 1;
    }

    .kickoff-dur {
      display: none;
    }

    .kickoff-title {
      grid-column: 1 / -1;
    }

    .kickoff-summary {
      grid-column: 1 / -1;
      max-width: none;
    }

    .next-card {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  const handleText = '@leahbluewater';
  const handleEl = document.getElementById('typewriter-handle');
  let charIndex = 0;

  function typeWriter() {
    if (handleEl && charIndex < handleText.length) {
      handleEl.textContent = handleText.substring(0, charIndex + 1);
      charIndex++;
      setTimeout(typeWriter, 80 + Math.random() * 40);
    } else if (handleEl) {
      handleEl.innerHTML = handleText + '<span class="cursor">|</span>';
      const cursor = handleEl.querySelector('.cursor');
      if (cursor) {
        cursor.style.animation = 'blink 1s step-end infinite';
        cursor.style.color = 'var(--clr-accent)';
      }
    }
  }

  setTimeout(typeWriter, 800);

  // ── Single RAF loop drives everything ───────────────────────────────────────
  const haloInner = document.querySelector('.kickoff-badge-halo:not(.kickoff-badge-halo--outer)');
  const haloOuter = document.querySelector('.kickoff-badge-halo--outer');
  const cardRing  = document.querySelector('.next-card-ring-halo');
  const badge     = document.getElementById('kickoff-badge');
  const card      = document.getElementById('next-card');

  const INNER_MS  = 18000;
  const OUTER_MS  = 27000;
  const CARD_MS   = 18000;
  const ORBIT_MS  = 18000;

  const BADGE_HALF = 24;

  let rafStart = null;

  function tick(ts) {
    if (rafStart === null) rafStart = ts;
    const elapsed = ts - rafStart;

    if (haloInner) haloInner.style.transform = `rotate(${(elapsed / INNER_MS) * 360}deg)`;
    if (haloOuter) haloOuter.style.transform = `rotate(${-(elapsed / OUTER_MS) * 360}deg)`;
    if (cardRing)  cardRing.style.transform  = `rotate(${(elapsed / CARD_MS) * 360}deg)`;

    if (badge && card) {
      const w = card.offsetWidth;
      const h = card.offsetHeight;
      const progress  = (elapsed % ORBIT_MS) / ORBIT_MS;
      const perimeter = 2 * (w + h);
      const dist      = progress * perimeter;

      let cx, cy;

      if (dist <= w) {
        cx = dist;
        cy = 0;
      } else if (dist <= w + h) {
        cx = w;
        cy = dist - w;
      } else if (dist <= 2 * w + h) {
        cx = w - (dist - w - h);
        cy = h;
      } else {
        cx = 0;
        cy = h - (dist - 2 * w - h);
      }

      badge.style.left      = `${cx - BADGE_HALF}px`;
      badge.style.top       = `${cy - BADGE_HALF}px`;
      badge.style.transform = 'none';
    }

    requestAnimationFrame(tick);
  }

  requestAnimationFrame(tick);

  // ── Countdown ────────────────────────────────────────────────────────────────
  const cardEl       = document.getElementById('next-card');
  const targetIso    = cardEl?.dataset?.target;
  const hasUrl       = cardEl?.dataset?.hasUrl === 'true';
  const countdownEl  = document.getElementById('next-card-countdown');

  function getCountdown() {
    if (!targetIso) return '--:--:--';
    const now    = new Date();
    const target = new Date(targetIso);
    const diff   = target - now;

    if (diff <= 0) {
      return hasUrl ? 'LIVE NOW' : 'STARTING SOON';
    }

    const h   = Math.floor(diff / 3600000);
    const m   = Math.floor((diff % 3600000) / 60000);
    const s   = Math.floor((diff % 60000) / 1000);
    const pad = (n) => String(n).padStart(2, '0');
    return `${pad(h)}:${pad(m)}:${pad(s)}`;
  }

  if (countdownEl) {
    const tickCd = () => { countdownEl.textContent = getCountdown(); };
    tickCd();
    setInterval(tickCd, 1000);
  }
</script>
