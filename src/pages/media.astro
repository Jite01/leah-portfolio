---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

// Static media data (replace with import from .json/store as needed)
const mediaItems = [
  {
    type: 'day-in-finance',
    date: '2025-01-10',
    headline: 'BTC holds $96K as ETF inflows hit $500M weekly',
    url: 'https://twitter.com/leahbluewater/status/placeholder-1',
  },
  {
    type: 'how-to',
    title: 'Buy Doginal Dogs in Under 5 Minutes',
    desc: 'Step-by-step guide to your first inscription purchase on Dogecoin.',
    url: 'https://twitter.com/leahbluewater/status/placeholder-2',
  },
  {
    type: 'article',
    title: 'Why WAT Is the New Trading Session You Should Watch',
    excerpt: 'West African retail volume is quietly moving markets. Here\'s the data.',
    url: 'https://twitter.com/leahbluewater/status/placeholder-3',
  },
];
---

<Layout title="Media — Leah Bluewater" description="All media output by Leah Bluewater.">
  <Nav slot="nav" />
  <main class="fade-in" id="main-content">
    <header class="section-header">
      <h1 class="section-heading" style="display:inline-flex;align-items:center;gap:0.75em;">
        Media
        <span class="badge badge-dark" style="font-size:var(--fs-xs);" aria-label="TypeMedia affiliate">
          TypeMedia
        </span>
      </h1>
      <p class="section-sub mono-label text-muted">Threads, guides, and articles</p>
    </header>
    <div class="media-grid">
      {mediaItems.map(item => (
        <article class="card media-card" data-type={item.type}>
          <span class="media-type-tag badge badge-accent">
            {item.type === 'day-in-finance' ? 'Day in Finance'
             : item.type === 'how-to'       ? 'How-To'
             :                                'Article'}
          </span>
          {item.type === 'day-in-finance' && (
            <>
              <p class="media-date mono-label text-muted">{item.date}</p>
              <p class="media-headline">{item.headline}</p>
            </>
          )}
          {item.type === 'how-to' && (
            <>
              <h3 class="media-title">{item.title}</h3>
              <p class="media-desc text-muted">{item.desc}</p>
            </>
          )}
          {item.type === 'article' && (
            <>
              <h3 class="media-title">{item.title}</h3>
              <p class="media-desc text-muted">{item.excerpt}</p>
            </>
          )}
          <a href={item.url} target="_blank" rel="noopener noreferrer" class="link-accent media-cta">
            Read on X ↗
          </a>
        </article>
      ))}
    </div>
  </main>
</Layout>

<style is:global>
.fade-in {
  animation: fade-in-page 0.37s var(--ease-out) both;
}
@keyframes fade-in-page {
  from {opacity:0;}
  to {opacity:1;}
}
</style>
