---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import mediaData from '../data/media.json';

const { dayInFinance, highlights, previousDayInFinance } = mediaData;

function lastDigitOfDay(dateStr) {
  const day = dateStr.split('-')[2];
  return { prefix: day.slice(0, -1), blink: day.slice(-1) };
}

const latestDay = lastDigitOfDay(dayInFinance.date);
const prevDay   = lastDigitOfDay(previousDayInFinance.date);
---

<Layout
  title="Media — Leah Bluewater"
  description="Day in Finance updates, curated highlights, and market commentary from @leahbluewater."
>
  <Nav slot="nav" />

  <div class="media-hero-bg" aria-hidden="true"></div>

  <section class="section media-section" aria-labelledby="media-heading">
    <div class="container">
      <header class="section-header">
        <h2 class="section-heading" id="media-heading">Media</h2>
        <p class="section-sub mono-label">
          <span class="sub-item" data-sub>Market updates</span>
          <span class="sub-sep">·</span>
          <span class="sub-item" data-sub>Curated picks</span>
          <span class="sub-sep">·</span>
          <span class="sub-item" data-sub>Commentary</span>
        </p>
      </header>

      <div class="media-grid">

        <!-- Card 1: Latest Day in Finance -->
        <article class="card media-card" data-type="day-in-finance">
          <span class="media-type-tag badge badge-accent badge--travel">
            Day in Finance
            <svg class="badge-svg" aria-hidden="true" focusable="false">
              <rect class="badge-snake badge-snake--ccw" pathLength="1" />
            </svg>
          </span>
          <p class="media-date mono-label text-muted">
            {dayInFinance.date.slice(0, 8)}{latestDay.prefix}<span class="blink-digit">{latestDay.blink}</span>
          </p>
          <div class="ticker-headline" id="ticker-headline" data-headline={dayInFinance.headline}></div>
          <a href={dayInFinance.url} target="_blank" rel="noopener noreferrer" class="link-accent media-cta">
            Watch on X ↗
          </a>
        </article>

        <!-- Card 2: Highlights — clockwise (anti-counter-clockwise) -->
        <article class="card media-card media-card--highlight" data-type="highlights">
          <span class="media-type-tag badge badge-dark badge--travel">
            Highlights
            <svg class="badge-svg" aria-hidden="true" focusable="false">
              <rect class="badge-snake badge-snake--cw" pathLength="1" />
            </svg>
          </span>
          <h3 class="media-title">{highlights.title}</h3>
          <p class="media-desc text-muted">{highlights.desc}</p>
          <a href={highlights.url} target="_blank" rel="noopener noreferrer" class="link-accent media-cta">
            Read on X ↗
          </a>
        </article>

        <!-- Card 3: Previous Day in Finance -->
        <article class="card media-card" data-type="day-in-finance">
          <span class="media-type-tag badge badge-accent badge--travel">
            Day in Finance
            <svg class="badge-svg" aria-hidden="true" focusable="false">
              <rect class="badge-snake badge-snake--ccw" pathLength="1" />
            </svg>
          </span>
          <p class="media-date mono-label text-muted">
            {previousDayInFinance.date.slice(0, 8)}{prevDay.prefix}<span class="blink-digit">{prevDay.blink}</span>
          </p>
          <p class="media-headline" style="white-space: pre-line;">{previousDayInFinance.headline}</p>
          <a href={previousDayInFinance.url} target="_blank" rel="noopener noreferrer" class="link-accent media-cta">
            Watch on X ↗
          </a>
        </article>

      </div>
    </div>
  </section>
</Layout>

<style>
  /* ─── Hero bg: breathing opacity ─── */
  .media-hero-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    background-image: url('/media_hero.jpg');
    background-size: cover;
    background-position: center center;
    pointer-events: none;
    animation: bg-breathe 7s ease-in-out infinite alternate;
  }

  @keyframes bg-breathe {
    from { opacity: 0.65; }
    to   { opacity: 0.87; }
  }

  /* ─── Section ─── */
  .media-section {
    position: relative;
    z-index: 1;
  }

  /* ─── Subtitle cycling ─── */
  .sub-sep {
    margin-inline: 0.35em;
    color: var(--clr-text-muted);
  }

  .sub-item {
    border-radius: 4px;
    padding: 0.1em 0.25em;
    transition:
      background-color 350ms cubic-bezier(0.16, 1, 0.3, 1),
      color            350ms cubic-bezier(0.16, 1, 0.3, 1),
      padding          350ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sub-item.is-lit {
    background-color: #ffffff;
    color: #fcd34d;
    padding: 0.1em 0.55em;
  }

  /* ─── Media grid ─── */
  .media-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(0, auto);
    gap: var(--space-5);
    align-items: start;
  }

  @media (max-width: 768px) {
    .media-grid { grid-template-columns: 1fr; }
  }

  .media-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
  }

  .media-card--highlight {
    border-color: var(--clr-text);
    box-shadow: 0 0 0 1px var(--clr-text);
    min-height: calc(var(--space-6) * 2 + 1.75 * 200px);
  }

  .media-card--highlight:hover {
    border-color: var(--clr-accent);
    box-shadow: 0 0 0 1px var(--clr-accent);
  }

  /* ─── Travelling badge border — snake typewriter ─── */
  .badge--travel {
    position: relative;
    overflow: visible;
  }

  .badge-svg {
    position: absolute;
    inset: -1px;
    width: calc(100% + 2px);
    height: calc(100% + 2px);
    pointer-events: none;
    overflow: visible;
  }

  .badge-snake {
    x: 1px;
    y: 1px;
    width: calc(100% - 2px);
    height: calc(100% - 2px);
    rx: 999px;
    fill: none;
    stroke: #0077b6;
    stroke-width: 1.5;
    /* ~70% of perimeter visible — long enough to read as "the border" */
    stroke-dasharray: 0.70 0.30;
    stroke-linecap: butt;
  }

  /* Counter-clockwise: dashoffset goes positive */
  .badge-snake--ccw {
    animation: snake-ccw 2.4s linear infinite;
  }

  /* Clockwise: dashoffset goes negative */
  .badge-snake--cw {
    animation: snake-cw 2.4s linear infinite;
  }

  @keyframes snake-ccw {
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: 1; }
  }

  @keyframes snake-cw {
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: -1; }
  }

  /* ─── Badge layout helpers ─── */
  .media-type-tag { align-self: flex-start; }
  .media-date     { font-size: var(--fs-xs); }

  .blink-digit {
    animation: blink 1s step-end infinite;
    color: var(--clr-accent);
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .media-headline,
  .media-title {
    font-family: var(--font-heading);
    font-size: var(--fs-md);
    font-weight: var(--fw-bold);
    line-height: 1.3;
    letter-spacing: -0.01em;
    flex: 1;
  }

  .media-desc {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    line-height: 1.5;
    flex: 1;
  }

  .media-cta { margin-top: auto; }

  /* ─── Ticker ─── */
  .ticker-headline {
    font-family: var(--font-heading);
    font-size: var(--fs-md);
    font-weight: var(--fw-bold);
    line-height: 1.5;
    letter-spacing: -0.01em;
    min-height: calc(1.5em * 3);
    display: flex;
    flex-direction: column;
    gap: 0.3em;
  }

  .ticker-line {
    display: block;
    white-space: nowrap;
    overflow: hidden;
    min-height: 1.5em;
  }

  .ticker-line.is-active::after {
    content: '|';
    animation: blink 1s step-end infinite;
    color: var(--clr-accent);
    margin-left: 2px;
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .media-hero-bg   { animation: none; opacity: 0.75; }
    .badge-snake     { animation: none; }
    .sub-item        { transition: none; }
  }
</style>

<script>
  /* ── Subtitle cycling ── */
  (function () {
    const items = Array.from(document.querySelectorAll('[data-sub]'));
    if (!items.length) return;
    let idx = 0;
    function light() {
      items.forEach(el => el.classList.remove('is-lit'));
      items[idx].classList.add('is-lit');
      idx = (idx + 1) % items.length;
    }
    light();
    setInterval(light, 2200);
  })();

  /* ── Ticker typewriter ── */
  (function () {
    const container = document.getElementById('ticker-headline');
    if (!container) return;

    const headline = container.dataset.headline || '';
    const lines = headline.split('\n').filter(l => l.trim().length > 0);
    if (!lines.length) return;

    const lineEls = lines.map(text => {
      const span = document.createElement('span');
      span.className = 'ticker-line';
      container.appendChild(span);
      return { el: span, chars: Array.from(text.trim()) };
    });

    let activeIndex = 0;
    let charIndex   = 0;
    let phase       = 'typing';

    const TYPE_SPEED     = 60;
    const PAUSE_DURATION = 1200;

    function tick() {
      const active = lineEls[activeIndex];
      if (phase === 'typing') {
        active.el.classList.add('is-active');
        if (charIndex < active.chars.length) {
          active.el.textContent = active.chars.slice(0, charIndex + 1).join('');
          charIndex++;
          setTimeout(tick, TYPE_SPEED);
        } else {
          active.el.classList.remove('is-active');
          phase = 'pause';
          setTimeout(() => { phase = 'erasing'; tick(); }, PAUSE_DURATION);
        }
      } else if (phase === 'erasing') {
        active.el.style.opacity    = '0';
        active.el.style.transition = 'opacity 0.3s ease';
        setTimeout(() => {
          active.el.textContent    = '';
          active.el.style.opacity  = '1';
          active.el.style.transition = '';
          activeIndex = (activeIndex + 1) % lineEls.length;
          charIndex   = 0;
          phase       = 'typing';
          tick();
        }, 300);
      }
    }

    tick();
  })();
</script>
