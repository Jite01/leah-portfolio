---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import mediaData from '../data/media.json';

const { dayInFinance, highlights, previousDayInFinance } = mediaData;

// Extract last digit of day for blinking effect
function lastDigitOfDay(dateStr) {
  const day = dateStr.split('-')[2];
  return {
    prefix: day.slice(0, -1),
    blink: day.slice(-1)
  };
}

const latestDay = lastDigitOfDay(dayInFinance.date);
const prevDay = lastDigitOfDay(previousDayInFinance.date);
---

<<Layout
  title="Media — Leah Bluewater"
  description="Day in Finance updates, curated highlights, and market commentary from @leahbluewater."
>
  <Nav slot="nav" />

  <div class="media-hero-bg" aria-hidden="true"></div>

  <section class="section media-section" aria-labelledby="media-heading">
    <div class="container">
      <header class="section-header">
        <h2 class="section-heading" id="media-heading">Media</h2>
        <p class="section-sub mono-label">Market updates · Curated picks · Commentary</p>
      </header>

      <div class="media-grid">
        <!-- Card 1: Latest Day in Finance -->
        <article class="card media-card" data-type="day-in-finance">
          <span class="media-type-tag badge badge-accent">Day in Finance</span>
          <p class="media-date mono-label text-muted">
            {dayInFinance.date.slice(0, 8)}{latestDay.prefix}<span class="blink-digit">{latestDay.blink}</span>
          </p>
          <div class="ticker-headline" id="ticker-headline" data-headline={dayInFinance.headline}></div>
          <a
            href={dayInFinance.url}
            target="_blank"
            rel="noopener noreferrer"
            class="link-accent media-cta"
          >
            Watch on X ↗
          </a>
        </article>

        <!-- Card 2: Highlights (1.75× taller) -->
        <article class="card media-card media-card--highlight" data-type="highlights">
          <span class="media-type-tag badge badge-dark">Highlights</span>
          <h3 class="media-title">{highlights.title}</h3>
          <p class="media-desc text-muted">{highlights.desc}</p>
          <a
            href={highlights.url}
            target="_blank"
            rel="noopener noreferrer"
            class="link-accent media-cta"
          >
            Read on X ↗
          </a>
        </article>

        <!-- Card 3: Previous Day in Finance -->
        <article class="card media-card" data-type="day-in-finance">
          <span class="media-type-tag badge badge-accent">Day in Finance</span>
          <p class="media-date mono-label text-muted">
            {previousDayInFinance.date.slice(0, 8)}{prevDay.prefix}<span class="blink-digit">{prevDay.blink}</span>
          </p>
          <p class="media-headline" style="white-space: pre-line;">{previousDayInFinance.headline}</p>
          <a
            href={previousDayInFinance.url}
            target="_blank"
            rel="noopener noreferrer"
            class="link-accent media-cta"
          >
            Watch on X ↗
          </a>
        </article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .media-hero-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    background-image: url('/media_hero.jpg');
    background-size: cover;
    background-position: center center;
    opacity: 0.70;
    pointer-events: none;
  }

  .media-section {
    position: relative;
    z-index: 1;
  }

  .media-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(0, auto);
    gap: var(--space-5);
    align-items: start;
  }

  @media (max-width: 768px) {
    .media-grid {
      grid-template-columns: 1fr;
    }
  }

  .media-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
  }

  .media-card--highlight {
    border-color: var(--clr-text);
    box-shadow: 0 0 0 1px var(--clr-text);
    min-height: calc(var(--space-6) * 2 + 1.75 * 200px);
    /* 1.75× the approximate content height of a standard card */
  }

  .media-card--highlight:hover {
    border-color: var(--clr-accent);
    box-shadow: 0 0 0 1px var(--clr-accent);
  }

  .media-type-tag {
    align-self: flex-start;
  }

  .media-date {
    font-size: var(--fs-xs);
  }

  .blink-digit {
    animation: blink 1s step-end infinite;
    color: var(--clr-accent);
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .media-headline,
  .media-title {
    font-family: var(--font-heading);
    font-size: var(--fs-md);
    font-weight: var(--fw-bold);
    line-height: 1.3;
    letter-spacing: -0.01em;
    flex: 1;
  }

  .media-desc {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    line-height: 1.5;
    flex: 1;
  }

  .media-cta {
    margin-top: auto;
  }

  /* ── Ticker ── */
  .ticker-headline {
    font-family: var(--font-heading);
    font-size: var(--fs-md);
    font-weight: var(--fw-bold);
    line-height: 1.5;
    letter-spacing: -0.01em;
    min-height: calc(1.5em * 3);
    display: flex;
    flex-direction: column;
    gap: 0.3em;
  }

  .ticker-line {
    display: block;
    white-space: nowrap;
    overflow: hidden;
    min-height: 1.5em;
  }

  .ticker-line.is-active::after {
    content: '|';
    animation: blink 1s step-end infinite;
    color: var(--clr-accent);
    margin-left: 2px;
  }
</style>

<script>
  (function() {
    const container = document.getElementById('ticker-headline');
    if (!container) return;

    const headline = container.dataset.headline || '';
    const lines = headline.split('\n').filter(l => l.trim().length > 0);
    if (lines.length === 0) return;

    const lineEls = lines.map(text => {
      const span = document.createElement('span');
      span.className = 'ticker-line';
      container.appendChild(span);
      return { el: span, text: text.trim(), chars: Array.from(text.trim()) };
    });

    let activeIndex = 0;
    let charIndex = 0;
    let phase = 'typing';
    let pauseTimer = null;

    const TYPE_SPEED = 60;
    const PAUSE_DURATION = 1200;

    function tick() {
      const active = lineEls[activeIndex];

      if (phase === 'typing') {
        active.el.classList.add('is-active');
        if (charIndex < active.chars.length) {
          active.el.textContent = active.chars.slice(0, charIndex + 1).join('');
          charIndex++;
          setTimeout(tick, TYPE_SPEED);
        } else {
          active.el.classList.remove('is-active');
          phase = 'pause';
          pauseTimer = setTimeout(() => {
            phase = 'erasing';
            tick();
          }, PAUSE_DURATION);
        }
      } else if (phase === 'erasing') {
        active.el.style.opacity = '0';
        active.el.style.transition = 'opacity 0.3s ease';
        
        setTimeout(() => {
          active.el.textContent = '';
          active.el.style.opacity = '1';
          active.el.style.transition = '';
          
          activeIndex = (activeIndex + 1) % lineEls.length;
          charIndex = 0;
          phase = 'typing';
          tick();
        }, 300);
      }
    }

    tick();
  })();
</script>
