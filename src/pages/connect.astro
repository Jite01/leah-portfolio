---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<<Layout
  title="Connect — Leah Bluewater"
  description="Connect with Leah Bluewater. Crypto & finance voice on X."
>
  <Nav slot="nav" />

  <main class="connect">
    <div class="connect-hero" aria-hidden="true">
      <img
        src="/hero_4fps.gif"
        alt=""
        loading="eager"
        decoding="async"
        draggable="false"
      />
    </div>

    <div class="connect-body">
      <h1 class="connect-h1">Connect</h1>

      <nav class="connect-links" aria-label="Social links">
        <a
          href="https://x.com/leahbluewater"
          target="_blank"
          rel="noopener noreferrer"
          class="connect-link"
        >
          @leahbluewater
        </a>
        <span class="connect-divider" aria-hidden="true">·</span>
        <a
          href="https://x.com/doginaldogs"
          target="_blank"
          rel="noopener noreferrer"
          class="connect-link"
        >
          Doginal Dogs
        </a>
      </nav>

      <a
        href="https://x.com/messages/compose?recipient_id=555216272"
        target="_blank"
        rel="noopener noreferrer"
        class="connect-dm"
      >
        Slide into DMs ↗
      </a>
    </div>

    <footer class="connect-footer">
      <p class="connect-copyright">© 2026 Leah Bluewater. All rights reserved.</p>
    </footer>
  </main>
</Layout>

<style>
  .connect {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-8) var(--space-4);
    overflow: hidden;
  }

  .connect-hero {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.12;
    pointer-events: none;
  }

  .connect-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }

  .connect-body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .connect-h1 {
    font-family: var(--font-heading);
    font-weight: var(--fw-extrabold);
    font-size: var(--fs-3xl);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--clr-text);
  }

  .connect-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
  }

  .connect-link {
    color: var(--clr-text);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .connect-link:hover {
    color: var(--clr-accent);
  }

  .connect-divider {
    color: var(--clr-text-faint);
    user-select: none;
  }

  .connect-dm {
    font-family: var(--font-heading);
    font-weight: var(--fw-bold);
    font-size: var(--fs-lg);
    color: var(--clr-accent);
    border-bottom: 2px solid currentColor;
    padding-bottom: 2px;
    margin-top: var(--space-2);
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .connect-dm:hover {
    opacity: 0.6;
  }

  .connect-footer {
    position: absolute;
    bottom: var(--space-6);
    left: 0;
    right: 0;
    z-index: 1;
    text-align: center;
  }

  .connect-copyright {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--clr-text-faint);
    letter-spacing: 0.05em;
  }
</style>
