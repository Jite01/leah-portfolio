---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout
  title="Connect — Leah Bluewater"
  description="Connect with Leah Bluewater. Crypto & finance voice on X."
>
  <Nav slot="nav" />

  <main class="connect">

    <div class="connect-hero" aria-hidden="true">
      <img
        src="/hero_4fps.gif"
        alt=""
        loading="eager"
        decoding="async"
        draggable="false"
      />
    </div>

    <div class="connect-body">
      <h1 class="connect-h1">Connect</h1>

      <nav class="connect-links" aria-label="Social links">
        <a
          href="https://x.com/leahbluewater"
          target="_blank"
          rel="noopener noreferrer"
          class="connect-link"
        >
          @leahbluewater
        </a>
        <span class="connect-divider" aria-hidden="true">·</span>
        <a
          href="https://x.com/doginaldogs"
          target="_blank"
          rel="noopener noreferrer"
          class="connect-link"
        >
          Doginal Dogs
        </a>
      </nav>

      <a
        href="https://x.com/messages/compose?recipient_id=555216272"
        target="_blank"
        rel="noopener noreferrer"
        class="connect-dm"
      >
        Slide into DMs ↗
      </a>
    </div>

    <footer class="connect-footer">
      <p class="connect-copyright">© 2026 Leah Bluewater. All rights reserved.</p>
    </footer>

  </main>
</Layout>

<style>
  .connect {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding-bottom: var(--space-8);
    background: var(--clr-bg, #ffffff);
    text-align: center;
  }

  /* ── GIF container ─────────────────────────────────────── */
  .connect-hero {
    width: 100%;
    max-width: 860px;
    max-height: 52vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    /*
      Radial oval mask dissolves the rectangular GIF into the white page.
      Opaque in centre, fully transparent at all four edges.
      Mimics the dithered pixel-border look.
    */
    -webkit-mask-image: radial-gradient(
      ellipse 78% 72% at 50% 52%,
      black 38%,
      transparent 100%
    );
    mask-image: radial-gradient(
      ellipse 78% 72% at 50% 52%,
      black 38%,
      transparent 100%
    );
  }

  .connect-hero img {
    width: 100%;
    height: auto;
    display: block;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    object-fit: cover;
    /* Pull frame down slightly so characters sit at mask centre */
    object-position: center 55%;
  }

  /* ── Text — lives below the GIF ────────────────────────── */
  .connect-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    /* Slight negative pull so text feels attached to image bottom */
    margin-top: calc(var(--space-6) * -1);
    padding: 0 var(--space-4);
    position: relative;
    z-index: 1;
  }

  .connect-h1 {
    font-family: var(--font-heading);
    font-weight: var(--fw-extrabold);
    font-size: var(--fs-3xl);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--clr-text);
  }

  .connect-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
  }

  .connect-link {
    color: var(--clr-text);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .connect-link:hover {
    color: var(--clr-accent);
  }

  .connect-divider {
    color: var(--clr-text-faint);
    user-select: none;
  }

  .connect-dm {
    font-family: var(--font-heading);
    font-weight: var(--fw-bold);
    font-size: var(--fs-lg);
    color: var(--clr-accent);
    border-bottom: 2px solid currentColor;
    padding-bottom: 2px;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .connect-dm:hover {
    opacity: 0.6;
  }

  /* ── Footer ────────────────────────────────────────────── */
  .connect-footer {
    margin-top: auto;
    padding-top: var(--space-10);
  }

  .connect-copyright {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--clr-text-faint);
    letter-spacing: 0.05em;
  }

  /* ── Mobile ────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .connect-hero {
      max-height: 44vh;
      -webkit-mask-image: radial-gradient(
        ellipse 92% 70% at 50% 52%,
        black 28%,
        transparent 100%
      );
      mask-image: radial-gradient(
        ellipse 92% 70% at 50% 52%,
        black 28%,
        transparent 100%
      );
    }

    .connect-body {
      margin-top: calc(var(--space-4) * -1);
    }
  }
</style>
