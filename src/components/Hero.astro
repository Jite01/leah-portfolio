--- import WaveCanvas from "./WaveCanvas.jsx"; interface Props { handle?: string; tagline?: string; } const { handle = "@leiablue", tagline = "Writing at the water's edge.", } = Astro.props; --- <section class="hero" aria-label="Hero"> <!-- ── Background: photo + animated canvas ── --> <div class="hero__scene"> <img src="/images/hero.jpg" alt="Aerial view of ocean waves washing over white sand beach" class="hero__img" fetchpriority="high" decoding="async" draggable="false" /> <WaveCanvas client:only="react" /> <div class="hero__vignette" aria-hidden="true"></div> </div> <!-- ── Copy: sits on the sand side ── --> <div class="hero__copy"> <span class="hero__handle">{handle}</span> <h1 class="hero__name"> <span class="hero__name--warm">Leia</span> <span class="hero__name--ocean">Blue</span> </h1> <p class="hero__tagline">{tagline}</p> <a href="/blog" class="hero__cta" aria-label="Read the blog"> Read <span aria-hidden="true">→</span> </a> </div> <!-- ── Subtle scroll cue ── --> <div class="hero__scroll" aria-hidden="true"> <span class="hero__scroll-line"></span> </div> </section> <style> /* ─── Scaffold ─── */ .hero { position: relative; width: 100%; height: 100svh; min-height: 520px; overflow: hidden; background: #0d1c24; /* fallback while image loads */ } /* ─── Scene layer ─── */ .hero__scene { position: absolute; inset: 0; } .hero__img { width: 100%; height: 100%; object-fit: cover; /* Nudge left slightly so the diagonal waterline stays prominent */ object-position: 42% center; display: block; user-select: none; } /* Vignette: deepen the ocean side, breath on sand side */ .hero__vignette { position: absolute; inset: 0; background: linear-gradient(to right, rgba(4,18,28,0.30) 0%, transparent 52%), linear-gradient(to top, rgba(4,18,28,0.18) 0%, transparent 42%); pointer-events: none; } /* ─── Copy block ─── */ .hero__copy { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: center; align-items: flex-end; /* Push into the sand zone */ padding-right: clamp(2.5rem, 9vw, 8rem); padding-bottom: 3vh; text-align: right; pointer-events: none; /* let clicks fall through to scene */ } .hero__handle { display: block; font-family: "DM Mono", "Courier New", monospace; font-size: clamp(0.62rem, 1.1vw, 0.80rem); letter-spacing: 0.24em; text-transform: uppercase; color: rgba(56, 42, 28, 0.58); margin-bottom: 0.8rem; pointer-events: auto; } .hero__name { margin: 0; display: flex; flex-direction: column; align-items: flex-end; line-height: 0.88; } .hero__name--warm, .hero__name--ocean { font-family: "Cormorant Garamond", "Garamond", Georgia, serif; font-weight: 300; font-size: clamp(4.8rem, 12.5vw, 11rem); letter-spacing: -0.025em; display: block; line-height: 1; } .hero__name--warm { color: rgba(36, 26, 16, 0.87); } /* "Blue" — the ocean literally names the colour */ .hero__name--ocean { color: rgba(10, 98, 148, 0.83); } .hero__tagline { margin: 1.5rem 0 0; font-family: "Cormorant Garamond", Georgia, serif; font-size: clamp(0.88rem, 1.7vw, 1.08rem); font-style: italic; font-weight: 400; color: rgba(56, 42, 28, 0.50); letter-spacing: 0.04em; pointer-events: auto; } .hero__cta { display: inline-block; margin-top: 2rem; font-family: "DM Mono", monospace; font-size: 0.76rem; letter-spacing: 0.20em; text-transform: uppercase; color: rgba(10, 98, 148, 0.78); text-decoration: none; border-bottom: 1px solid rgba(10, 98, 148, 0.28); padding-bottom: 2px; transition: color 0.22s ease, border-color 0.22s ease; pointer-events: auto; } .hero__cta:hover { color: rgba(10, 98, 148, 1); border-color: rgba(10, 98, 148, 0.65); } /* ─── Scroll indicator ─── */ .hero__scroll { position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); } .hero__scroll-line { display: block; width: 1px; height: 54px; background: linear-gradient(to bottom, rgba(255,255,255,0.48), transparent); animation: scrollPulse 2.4s ease-in-out infinite; } @keyframes scrollPulse { 0%, 100% { opacity: 0.25; transform: scaleY(0.55) translateY(-10px); } 55% { opacity: 0.85; transform: scaleY(1.00) translateY(0); } } /* ─── Mobile ─── */ @media (max-width: 600px) { .hero__img { /* On narrow screens show more of the wave action */ object-position: 35% center; } .hero__copy { justify-content: flex-end; align-items: flex-start; text-align: left; padding-right: 0; padding-left: 1.6rem; padding-bottom: 5.5rem; } .hero__name { align-items: flex-start; } /* Sand text is now over water/foam on mobile — lighten everything */ .hero__handle { color: rgba(255, 255, 255, 0.52); } .hero__name--warm { color: rgba(255, 255, 255, 0.92); text-shadow: 0 2px 32px rgba(0, 0, 0, 0.10); } .hero__name--ocean { color: rgba(155, 222, 248, 0.92); text-shadow: 0 2px 32px rgba(0, 0, 0, 0.10); } .hero__tagline { color: rgba(255, 255, 255, 0.52); } .hero__cta { color: rgba(155, 222, 248, 0.88); border-color: rgba(155, 222, 248, 0.32); } } </style>
