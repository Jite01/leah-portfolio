---
---

<span class="water-canvas-wrap" aria-hidden="true">
  <canvas id="water-canvas" class="water-canvas"></canvas>
  <span class="water-text">water</span>
</span>

<style>
  .water-canvas-wrap {
    position: relative;
    display: inline-block;
    vertical-align: baseline;
    line-height: 1;
    font-family: var(--font-heading);
    font-weight: var(--fw-extrabold);
    font-size: inherit;
    letter-spacing: inherit;
  }

  .water-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  .water-text {
    position: relative;
    z-index: 2;
    color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
  }
</style>

<script>
  (function() {
    const wrap = document.querySelector('.water-canvas-wrap');
    const canvas = document.getElementById('water-canvas');
    if (!wrap || !canvas) return;
    
    const ctx = canvas.getContext('2d');
    const textEl = wrap.querySelector('.water-text');
    if (!ctx || !textEl) return;

    let width, height, dpr;
    let animId;
    let time = 0;
    
    const WAVE_COUNT = 5;
    const WAVE_SPEED = 0.02;
    const FILL_SPEED = 0.003;
    const DRAIN_SPEED = 0.008;
    
    let fillLevel = 0;
    let phase = 'filling';
    let phaseTimer = 0;
    
    function resize() {
      const rect = wrap.getBoundingClientRect();
      dpr = window.devicePixelRatio || 1;
      width = rect.width;
      height = rect.height;
      
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      canvas.style.width = width + 'px';
      canvas.style.height = height + 'px';
      
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    
    function drawTextMask() {
      const maskCanvas = document.createElement('canvas');
      const mctx = maskCanvas.getContext('2d');
      maskCanvas.width = width * dpr;
      maskCanvas.height = height * dpr;
      mctx.scale(dpr, dpr);
      
      const styles = window.getComputedStyle(textEl);
      const fontSize = parseFloat(styles.fontSize);
      const fontFamily = styles.fontFamily;
      
      mctx.fillStyle = '#ffffff';
      mctx.font = `800 ${fontSize}px ${fontFamily.split(',')[0].replace(/["']/g, '')}`;
      mctx.textBaseline = 'alphabetic';
      
      const metrics = mctx.measureText('water');
      const x = (width - metrics.width) / 2;
      const y = height * 0.78;
      
      mctx.fillText('water', x, y);
      
      const dataURL = maskCanvas.toDataURL();
      canvas.style.webkitMaskImage = `url(${dataURL})`;
      canvas.style.maskImage = `url(${dataURL})`;
      canvas.style.webkitMaskSize = `${width}px ${height}px`;
      canvas.style.maskSize = `${width}px ${height}px`;
      canvas.style.webkitMaskRepeat = 'no-repeat';
      canvas.style.maskRepeat = 'no-repeat';
      canvas.style.webkitMaskPosition = 'center';
      canvas.style.maskPosition = 'center';
    }
    
    function drawWater(t) {
      ctx.clearRect(0, 0, width, height);
      
      const waterHeight = height * fillLevel;
      const waterY = height - waterHeight;
      
      if (waterHeight <= 0.5) return;
      
      const grad = ctx.createLinearGradient(0, waterY, 0, height);
      grad.addColorStop(0, 'rgba(0, 180, 220, 0.95)');
      grad.addColorStop(0.3, 'rgba(0, 140, 200, 0.9)');
      grad.addColorStop(0.6, 'rgba(0, 100, 180, 0.95)');
      grad.addColorStop(1, 'rgba(0, 80, 160, 1)');
      
      ctx.beginPath();
      ctx.moveTo(0, height);
      
      for (let x = 0; x <= width; x += 1) {
        let y = waterY;
        for (let i = 0; i < WAVE_COUNT; i++) {
          const amp = 2 + i * 1.2;
          const freq = 0.015 + i * 0.008;
          const spd = WAVE_SPEED * (1 + i * 0.3);
          const ph = i * Math.PI / 3;
          y += Math.sin(x * freq + t * spd * 60 + ph) * amp;
        }
        ctx.lineTo(x, y);
      }
      
      ctx.lineTo(width, height);
      ctx.lineTo(0, height);
      ctx.closePath();
      ctx.fillStyle = grad;
      ctx.fill();
      
      ctx.beginPath();
      for (let x = 0; x <= width; x += 1) {
        let y = waterY;
        for (let i = 0; i < WAVE_COUNT; i++) {
          const amp = 2 + i * 1.2;
          const freq = 0.015 + i * 0.008;
          const spd = WAVE_SPEED * (1 + i * 0.3);
          const ph = i * Math.PI / 3;
          y += Math.sin(x * freq + t * spd * 60 + ph) * amp;
        }
        if (x === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.strokeStyle = 'rgba(120, 230, 255, 0.7)';
      ctx.lineWidth = 1.5;
      ctx.stroke();
      
      const bubbleCount = Math.floor(fillLevel * 15);
      for (let i = 0; i < bubbleCount; i++) {
        const bx = (Math.sin(t * 0.5 + i * 2.5) * 0.5 + 0.5) * width;
        const by = waterY + Math.random() * waterHeight * 0.7;
        const br = 0.8 + Math.sin(t + i) * 0.7;
        ctx.beginPath();
        ctx.arc(bx, by, Math.max(0.3, br), 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(200, 245, 255, 0.5)';
        ctx.fill();
      }
      
      ctx.globalCompositeOperation = 'screen';
      for (let i = 0; i < 6; i++) {
        const cx = (Math.sin(t * 0.3 + i * 1.2) * 0.5 + 0.5) * width;
        const cy = waterY + (Math.cos(t * 0.2 + i * 0.8) * 0.5 + 0.5) * waterHeight;
        const cr = 25 + Math.sin(t + i) * 12;
        const cgrad = ctx.createRadialGradient(cx, cy, 0, cx, cy, cr);
        cgrad.addColorStop(0, 'rgba(140, 235, 255, 0.2)');
        cgrad.addColorStop(1, 'rgba(140, 235, 255, 0)');
        ctx.beginPath();
        ctx.arc(cx, cy, cr, 0, Math.PI * 2);
        ctx.fillStyle = cgrad;
        ctx.fill();
      }
      ctx.globalCompositeOperation = 'source-over';
    }
    
    function updatePhase(dt) {
      phaseTimer += dt;
      switch (phase) {
        case 'filling':
          fillLevel += FILL_SPEED * dt * 60;
          if (fillLevel >= 1) { fillLevel = 1; phase = 'full'; phaseTimer = 0; }
          break;
        case 'full':
          if (phaseTimer > 120) { phase = 'draining'; phaseTimer = 0; }
          break;
        case 'draining':
          fillLevel -= DRAIN_SPEED * dt * 60;
          if (fillLevel <= 0) { fillLevel = 0; phase = 'empty'; phaseTimer = 0; }
          break;
        case 'empty':
          if (phaseTimer > 60) { phase = 'filling'; phaseTimer = 0; }
          break;
      }
    }
    
    let lastTime = 0;
    function animate(timestamp) {
      if (!lastTime) lastTime = timestamp;
      const dt = (timestamp - lastTime) / 16.67;
      lastTime = timestamp;
      time += 0.016;
      updatePhase(dt);
      drawWater(time);
      animId = requestAnimationFrame(animate);
    }
    
       function init() {
      lastTime = 0;
      time = 0;
      phase = 'filling';
      phaseTimer = 0;
      fillLevel = 0;
      resize();
      drawTextMask();
      if (animId) cancelAnimationFrame(animId);
      animId = requestAnimationFrame(animate);
    }
    
    function cleanup() {
      if (animId) cancelAnimationFrame(animId);
      animId = null;
    }

    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    
    let resizeTimeout;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        cleanup();
        resize();
        drawTextMask();
        animId = requestAnimationFrame(animate);
      }, 150);
    });
    
    document.addEventListener('astro:before-preparation', cleanup);
    document.addEventListener('astro:page-load', init);
  })();
</script>
