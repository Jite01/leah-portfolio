---
import kickoffData from '../data/kickoffs.json';

const { nextKickoff } = kickoffData;
const targetIso = `${nextKickoff.date}T11:00:00+01:00`;
const hasUrl = nextKickoff.url ? 'true' : 'false';
---

<div
  class="ticker-wrap"
  aria-label="The Kickoff countdown ticker"
  role="marquee"
  data-target={targetIso}
  data-has-url={hasUrl}
>
  <div class="ticker-track" id="ticker-track">
    <span class="ticker-item">
      THE KICKOFF
      <span class="ticker-sep">·</span>
      10AM UTC
      <span class="ticker-sep">·</span>
      5AM EST
      <span class="ticker-sep">·</span>
      4AM CST
      <span class="ticker-sep">·</span>
      11AM WAT
      <span class="ticker-sep">·</span>
      STARTS IN
      <span class="ticker-countdown" id="ticker-countdown">--:--:--</span>
    </span>
    <span class="ticker-item" aria-hidden="true">
      THE KICKOFF
      <span class="ticker-sep">·</span>
      10AM UTC
      <span class="ticker-sep">·</span>
      5AM EST
      <span class="ticker-sep">·</span>
      4AM CST
      <span class="ticker-sep">·</span>
      11AM WAT
      <span class="ticker-sep">·</span>
      STARTS IN
      <span class="ticker-countdown ticker-countdown-clone">--:--:--</span>
    </span>
  </div>
</div>

<style>
  .ticker-wrap {
    width: 100%;
    overflow: hidden;
    background: var(--clr-accent);
    border-top: 1px solid var(--clr-accent-dark);
    border-bottom: 1px solid var(--clr-accent-dark);
    padding-block: 10px;
    user-select: none;
  }

  .ticker-track {
    display: flex;
    width: max-content;
    animation: ticker-scroll 28s linear infinite;
    will-change: transform;
  }

  .ticker-track:hover {
    animation-play-state: paused;
  }

  .ticker-item {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding-inline: 48px;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    font-weight: var(--fw-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ffffff;
    white-space: nowrap;
  }

  .ticker-sep {
    color: rgba(255, 255, 255, 0.45);
    font-weight: var(--fw-regular);
  }

  .ticker-countdown {
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.08em;
    background: rgba(0, 0, 0, 0.2);
    padding: 2px 8px;
    border-radius: 2px;
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }

  .ticker-countdown.is-live {
    color: #ff4444;
    text-shadow: 0 0 10px rgba(255, 68, 68, 0.7);
    background: rgba(0, 0, 0, 0.35);
  }

  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
      justify-content: center;
    }
    .ticker-item:last-child {
      display: none;
    }
  }
</style>

<script>
  const wrap = document.querySelector('.ticker-wrap');
  const targetIso = wrap.dataset.target;
  const hasUrl = wrap.dataset.hasUrl === 'true';

  function getCountdown() {
    const now = new Date();
    const target = new Date(targetIso);
    const diff = target - now;

    if (diff <= 0) {
      if (hasUrl) return { text: 'LIVE NOW', live: true };
      return { text: 'STARTING SOON', live: false };
    }

    const h = Math.floor(diff / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    const pad = (n) => String(n).padStart(2, '0');
    return { text: `${pad(h)}:${pad(m)}:${pad(s)}`, live: false };
  }

  function tick() {
    const { text, live } = getCountdown();
    document.querySelectorAll('.ticker-countdown, .ticker-countdown-clone')
      .forEach(el => {
        el.textContent = text;
        el.classList.toggle('is-live', live);
      });
  }

  tick();
  setInterval(tick, 1000);
</script>
