---
import kickoffData from '../data/kickoffs.json';

const { nextKickoff } = kickoffData;
const targetIso = `${nextKickoff.date}T11:00:00+01:00`;
const hasUrl = nextKickoff.url ? 'true' : 'false';
---

<div class="ticker-shell">

  <div
    class="ticker-wrap"
    aria-label="The Kickoff countdown ticker"
    role="marquee"
    data-target={targetIso}
    data-has-url={hasUrl}
  >
    <div class="ticker-track" id="ticker-track">
      <span class="ticker-item">
        THE KICKOFF
        <span class="ticker-sep">·</span>
        10AM UTC
        <span class="ticker-sep">·</span>
        5AM EST
        <span class="ticker-sep">·</span>
        4AM CST
        <span class="ticker-sep">·</span>
        11AM WAT
        <span class="ticker-sep">·</span>
        STARTS IN
        <span class="ticker-countdown" id="ticker-countdown">--:--:--</span>
      </span>
      <span class="ticker-item" aria-hidden="true">
        THE KICKOFF
        <span class="ticker-sep">·</span>
        10AM UTC
        <span class="ticker-sep">·</span>
        5AM EST
        <span class="ticker-sep">·</span>
        4AM CST
        <span class="ticker-sep">·</span>
        11AM WAT
        <span class="ticker-sep">·</span>
        STARTS IN
        <span class="ticker-countdown ticker-countdown-clone">--:--:--</span>
      </span>
    </div>
  </div>

  <!-- Gold bell — sits outside ticker-wrap so overflow:hidden doesn't clip it -->
  <button
    class="ticker-bell"
    id="ticker-bell"
    aria-label="Get notified when Kickoff starts"
    aria-pressed="false"
    title="Notify me at Kickoff"
  >
    <svg class="bell-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
    </svg>
    <span class="bell-dot" id="bell-dot" aria-hidden="true"></span>
  </button>

</div>

<style>
  /* ── Shell: positions bell relative to the ticker bar ── */
  .ticker-shell {
    position: relative;
    width: 100%;
  }

  /* ── Ticker (unchanged) ── */
  .ticker-wrap {
    width: 100%;
    overflow: hidden;
    background: var(--clr-accent);
    border-top: 1px solid var(--clr-accent-dark);
    border-bottom: 1px solid var(--clr-accent-dark);
    padding-block: 10px;
    /* right padding reserves space for the bell */
    padding-right: 56px;
    user-select: none;
  }

  .ticker-track {
    display: flex;
    width: max-content;
    animation: ticker-scroll 28s linear infinite;
    will-change: transform;
  }

  .ticker-track:hover {
    animation-play-state: paused;
  }

  .ticker-item {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding-inline: 48px;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    font-weight: var(--fw-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ffffff;
    white-space: nowrap;
  }

  .ticker-sep {
    color: rgba(255, 255, 255, 0.45);
    font-weight: var(--fw-regular);
  }

  .ticker-countdown {
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.08em;
    background: rgba(0, 0, 0, 0.2);
    padding: 2px 8px;
    border-radius: 2px;
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }

  .ticker-countdown.is-live {
    color: #ff4444;
    text-shadow: 0 0 10px rgba(255, 68, 68, 0.7);
    background: rgba(0, 0, 0, 0.35);
  }

  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Bell button ── */
  .ticker-bell {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #d4a000;
    border: none;
    border-left: 1px solid rgba(0, 0, 0, 0.18);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: background 150ms ease, transform 100ms ease;
    /* subtle left-edge gradient to blend with ticker */
    box-shadow: -4px 0 12px rgba(0, 0, 0, 0.15);
  }

  .ticker-bell:hover {
    background: #e6b000;
  }

  .ticker-bell:active {
    transform: scale(0.93);
  }

  /* subscribed state — accent green tint */
  .ticker-bell.is-subscribed {
    background: #b8860b;
  }

  .bell-icon {
    width: 18px;
    height: 18px;
    color: #ffffff;
    flex-shrink: 0;
    transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ticker-bell:hover .bell-icon {
    transform: rotate(-12deg);
  }

  /* small dot indicator when subscribed */
  .bell-dot {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    border: 1.5px solid #d4a000;
    opacity: 0;
    transition: opacity 200ms ease;
  }

  .ticker-bell.is-subscribed .bell-dot {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
      justify-content: center;
    }
    .ticker-item:last-child {
      display: none;
    }
  }
</style>

<script>
  /* ── Countdown ── */
  const wrap = document.querySelector('.ticker-wrap');
  const targetIso = wrap.dataset.target;
  const hasUrl = wrap.dataset.hasUrl === 'true';

  function getCountdown() {
    const now    = new Date();
    const target = new Date(targetIso);
    const diff   = target - now;

    if (diff <= 0) {
      if (hasUrl) return { text: 'LIVE NOW', live: true };
      return { text: 'STARTING SOON', live: false };
    }

    const h   = Math.floor(diff / 3600000);
    const m   = Math.floor((diff % 3600000) / 60000);
    const s   = Math.floor((diff % 60000) / 1000);
    const pad = (n) => String(n).padStart(2, '0');
    return { text: `${pad(h)}:${pad(m)}:${pad(s)}`, live: false };
  }

  function tick() {
    const { text, live } = getCountdown();
    document.querySelectorAll('.ticker-countdown, .ticker-countdown-clone')
      .forEach(el => {
        el.textContent = text;
        el.classList.toggle('is-live', live);
      });
  }

  tick();
  setInterval(tick, 1000);

  /* ── Bell / Push subscription ── */
  const bell = document.getElementById('ticker-bell');

  function urlBase64ToUint8Array(base64String) {
    const padding = '='.repeat((4 - base64String.length % 4) % 4);
    const base64  = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
    const rawData = atob(base64);
    return Uint8Array.from([...rawData].map(c => c.charCodeAt(0)));
  }

  const VAPID_PUBLIC = 'BKs2VnDnNqsmzTG-KY8OH__usGsyFpMno8JFw3v-Ph0-9B4eqKvsGiFK8cldWlPuezbKofoaoCkN3fAwGj6j2WA';

  async function checkSubscribed() {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) return false;
    const reg = await navigator.serviceWorker.ready;
    const sub = await reg.pushManager.getSubscription();
    return !!sub;
  }

  async function subscribe() {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      alert('Push notifications are not supported in this browser.');
      return;
    }
    const reg = await navigator.serviceWorker.ready;
    const existing = await reg.pushManager.getSubscription();
    if (existing) { setSubscribed(true); return; }

    try {
      const sub = await reg.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: urlBase64ToUint8Array(VAPID_PUBLIC),
      });
      await fetch('/api/subscribe', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(sub),
      });
      setSubscribed(true);
    } catch (err) {
      console.error('Push subscription failed:', err);
    }
  }

  async function unsubscribe() {
    const reg = await navigator.serviceWorker.ready;
    const sub = await reg.pushManager.getSubscription();
    if (sub) {
      await sub.unsubscribe();
      await fetch('/api/subscribe', {
        method:  'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ endpoint: sub.endpoint }),
      });
    }
    setSubscribed(false);
  }

  function setSubscribed(on) {
    bell.classList.toggle('is-subscribed', on);
    bell.setAttribute('aria-pressed', String(on));
    bell.title = on ? 'Subscribed — click to cancel' : 'Notify me at Kickoff';
  }

  /* init */
  checkSubscribed().then(setSubscribed);

  bell.addEventListener('click', () => {
    if (bell.classList.contains('is-subscribed')) {
      unsubscribe();
    } else {
      subscribe();
    }
  });
</script>
