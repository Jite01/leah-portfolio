---
---

<a href="#main-content" class="skip-link">Skip to content</a>

<header class="nav-bar" id="nav-bar">
  <div class="nav-inner">
    <a href="/" class="nav-wordmark" aria-label="Leah Bluewater — home">
      <span class="nav-wordmark-name">LEAH</span>
      <span class="nav-wordmark-handle mono-label">@leahbluewater</span>
    </a>

    <button
      class="hamburger"
      id="hamburger"
      aria-controls="nav-overlay"
      aria-expanded="false"
      aria-label="Open navigation"
    >
      <span class="bar bar-1"></span>
      <span class="bar bar-2"></span>
      <span class="bar bar-3"></span>
    </button>
  </div>
</header>

<div class="nav-overlay" id="nav-overlay" aria-hidden="true">
  <div class="overlay-photo" aria-hidden="true"></div>

  <button
    class="overlay-close"
    id="overlay-close"
    aria-label="Close navigation"
  >
    <span class="bar bar-1"></span>
    <span class="bar bar-2"></span>
  </button>

  <nav class="overlay-nav" aria-label="Main navigation">
    <ol class="overlay-links">
      <li class="overlay-item">
        <a href="/" class="overlay-link" data-astro-reload>
          <span class="link-text">Kickoff</span>
        </a>
      </li>
      <li class="overlay-item">
        <a href="/media" class="overlay-link">
          <span class="link-text">Media</span>
        </a>
      </li>
      <li class="overlay-item">
        <a href="/collection" class="overlay-link">
          <span class="link-text">Collection</span>
        </a>
      </li>
      <li class="overlay-item">
        <a href="/connect" class="overlay-link">
          <span class="link-text">Connect</span>
        </a>
      </li>
    </ol>
    <div class="overlay-footer">
      <span class="mono-label" style="color: var(--clr-text-faint);">@leahbluewater · TypeMedia · Doginal Dogs</span>
    </div>
  </nav>
</div>

<style>
  .nav-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    height: 64px;
    background: var(--clr-bg);
    border-bottom: 1px solid var(--clr-border);
  }

  :root { --nav-h: 64px; }

  .nav-inner {
    max-width: var(--max-w-content);
    margin-inline: auto;
    padding-inline: var(--page-px);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-wordmark {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    text-decoration: none;
    line-height: 1;
  }

  .nav-wordmark-name {
    font-family: var(--font-heading);
    font-weight: var(--fw-extrabold);
    font-size: 1.1rem;
    letter-spacing: -0.01em;
    color: var(--clr-text);
    line-height: 1;
  }

  .nav-wordmark-handle {
    color: var(--clr-text-faint);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    line-height: 1;
    margin-top: 1px;
  }

  .hamburger {
    width: 36px;
    height: 36px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    gap: 5px;
    padding: 4px;
    position: relative;
    z-index: calc(var(--z-overlay) + 10);
    transition: opacity var(--dur-base) var(--ease-out);
    overflow: visible;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .hamburger .bar {
    display: block;
    height: 1.5px;
    background: var(--clr-text);
    border-radius: 1px;
    transform-origin: center;
    transition: width var(--dur-base) var(--ease-out),
                transform var(--dur-base) var(--ease-out),
                opacity var(--dur-base) var(--ease-out);
  }

  .hamburger .bar-1 { width: 24px; }
  .hamburger .bar-2 { width: 16px; }
  .hamburger .bar-3 { width: 20px; }

  .hamburger.is-active .bar-1 {
    transform: translateY(6.5px) rotate(45deg);
    width: 24px;
  }
  .hamburger.is-active .bar-2 {
    opacity: 0;
    width: 0;
  }
  .hamburger.is-active .bar-3 {
    transform: translateY(-6.5px) rotate(-45deg);
    width: 24px;
  }

  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-overlay);
    background: var(--clr-bg);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding-inline: var(--page-px);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-slow) var(--ease-out);
  }

  .nav-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .overlay-photo {
    position: absolute;
    inset: 0;
    background-image: url('/images/hero.jpg');
    background-size: cover;
    background-position: center 30%;
    opacity: 0.15;
    pointer-events: none;
  }

  .overlay-close {
    position: absolute;
    top: calc((64px - 36px) / 2);
    right: var(--page-px);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
    z-index: 1;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .overlay-close .bar {
    display: block;
    position: absolute;
    width: 24px;
    height: 1.5px;
    background: var(--clr-text);
    border-radius: 1px;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .overlay-close .bar-1 { transform: rotate(45deg); }
  .overlay-close .bar-2 { transform: rotate(-45deg); }

  .overlay-nav {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--max-w-content);
    margin-inline: auto;
  }

  .overlay-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .overlay-item {
    border-top: 1px solid var(--clr-border);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity var(--dur-slow) var(--ease-out),
                transform var(--dur-slow) var(--ease-out);
  }

  .overlay-item:last-child {
    border-bottom: 1px solid var(--clr-border);
  }

  .overlay-item:nth-child(1) { transition-delay: 60ms; }
  .overlay-item:nth-child(2) { transition-delay: 120ms; }
  .overlay-item:nth-child(3) { transition-delay: 180ms; }
  .overlay-item:nth-child(4) { transition-delay: 240ms; }

  .nav-overlay.is-open .overlay-item {
    opacity: 1;
    transform: translateY(0);
  }

  .overlay-link {
    display: flex;
    align-items: baseline;
    gap: var(--space-5);
    padding-block: clamp(1rem, 3vw, 1.75rem);
    text-decoration: none;
    color: var(--clr-text);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .overlay-link:hover {
    color: var(--clr-accent);
  }

  .link-text {
    font-family: var(--font-heading);
    font-weight: var(--fw-extrabold);
    font-size: clamp(2rem, 7vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .overlay-footer {
    margin-top: var(--space-7);
    opacity: 0;
    transition: opacity var(--dur-slow) var(--ease-out) 300ms;
  }

  .nav-overlay.is-open .overlay-footer {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-overlay, .overlay-item, .overlay-footer,
    .hamburger .bar, .overlay-close .bar {
      transition: none !important;
      animation: none !important;
    }
  }
</style>

<!-- Mote styles must be global so JS-created elements receive them -->
<style is:global>
  #mote-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 999999;
    overflow: hidden;
  }

  .mote {
    position: absolute;
    width: 48px;
    height: 48px;
    pointer-events: none;
    will-change: transform, opacity;
    animation: moteFall var(--fall-dur, 2200ms) cubic-bezier(0.12, 0.9, 0.3, 1) forwards;
  }
  .mote-halo {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      rgba(70, 85, 100, 0.25), rgba(180, 198, 215, 0.80),
      rgba(235, 245, 255, 1.00), rgba(255, 255, 255, 1.00),
      rgba(200, 215, 228, 0.85), rgba(150, 168, 185, 0.60),
      rgba(100, 118, 135, 0.35), rgba(70, 85, 100, 0.25)
    );
    animation: moteRingSpin var(--spin-a, 2.2s) linear infinite;
  }
  .mote-halo--outer {
    inset: -5px;
    background: conic-gradient(
      from 180deg,
      rgba(60, 80, 110, 0.00), rgba(100, 150, 200, 0.45),
      rgba(180, 210, 240, 0.70), rgba(100, 150, 200, 0.45),
      rgba(60, 80, 110, 0.00)
    );
    filter: blur(1px);
    animation: moteRingSpin var(--spin-b, 3.4s) linear infinite reverse;
  }
  .mote-face {
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    overflow: hidden;
    z-index: 2;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.12),
      inset 0 -1px 2px rgba(0, 0, 0, 0.55),
      0 0 12px rgba(140, 185, 230, 0.50),
      0 0 28px rgba(60, 130, 200, 0.25);
  }
  .mote-face img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    image-rendering: pixelated;
  }
    .mote-face--pox {
    background-image: var(--pox-src);
    background-size: 200% 200%;
    background-position: 50% 55%;
    background-repeat: no-repeat;
  }


  @keyframes moteRingSpin { to { transform: rotate(360deg); } }
  @keyframes moteFall {
    0%  { opacity: 0;    transform: translate(0, 0) scale(0.22) rotate(0deg); }
    7%  { opacity: 1;    transform: translate(var(--dx1), var(--dy1)) scale(1.10) rotate(var(--r1)); }
    68% { opacity: 0.90; transform: translate(var(--dx-mid), var(--dy-mid)) scale(0.95) rotate(var(--r-mid)); }
    100%{ opacity: 0;    transform: translate(var(--dx2), var(--dy2)) scale(0.70) rotate(var(--r2)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mote { animation: none !important; }
  }
</style>

<script>
  (function() {
    const PFP_SRC = '/pfp.jpg';
    const POX_SRC = '/pox.jpg';

    function rand(lo, hi) { return Math.random() * (hi - lo) + lo; }
    function px(n) { return n.toFixed(2) + 'px'; }
    function dg(n) { return n.toFixed(1) + 'deg'; }

    // One persistent fixed layer — created once, reused across Astro page loads
    let moteLayer = document.getElementById('mote-layer');
    if (!moteLayer) {
      moteLayer = document.createElement('div');
      moteLayer.id = 'mote-layer';
      document.body.appendChild(moteLayer);
    }

    function spawnMote(rect, localX, localY, imgSrc, isPox, delayMs) {
      setTimeout(() => {
        const mote = document.createElement('div');
        mote.className = 'mote';
        mote.style.left = px(rect.left + localX - 24);
        mote.style.top  = px(rect.top  + localY - 24);

        const haloOuter = document.createElement('div');
        haloOuter.className = 'mote-halo mote-halo--outer';

        const haloInner = document.createElement('div');
        haloInner.className = 'mote-halo';

        const face = document.createElement('div');
        face.className = isPox ? 'mote-face mote-face--pox' : 'mote-face';

        const img = document.createElement('img');
        img.src = imgSrc;
        img.alt = '';
        img.draggable = false;
        face.appendChild(img);

        mote.append(haloOuter, haloInner, face);

        mote.style.setProperty('--spin-a', rand(1.4, 3.0).toFixed(2) + 's');
        mote.style.setProperty('--spin-b', rand(2.6, 4.8).toFixed(2) + 's');
        mote.style.setProperty('--dx1',    px(rand(-22,  22)));
        mote.style.setProperty('--dy1',    px(rand(-28,  -6)));
        mote.style.setProperty('--dx-mid', px(rand(-70,  70)));
        mote.style.setProperty('--dy-mid', px(rand( 90, 200)));
        mote.style.setProperty('--dx2',    px(rand(-110, 110)));
        mote.style.setProperty('--dy2',    px(rand( 260, 440)));
        mote.style.setProperty('--r1',     dg(rand(-28,  28)));
        mote.style.setProperty('--r-mid',  dg(rand(-110, 110)));
        mote.style.setProperty('--r2',     dg(rand(-220, 220)));

        const dur = Math.round(rand(1900, 3100));
        mote.style.setProperty('--fall-dur', dur + 'ms');

        moteLayer.appendChild(mote);
        setTimeout(() => mote.remove(), dur + 80);
      }, delayMs);
    }

    function burst(btn) {
      const rect = btn.getBoundingClientRect();
      const W = rect.width;
      const H = rect.height;
      const motes = [
        { x: W * 0.38, y: H * 0.28, src: PFP_SRC, pox: false, d:  0  },
        { x: W * 0.50, y: H * 0.50, src: PFP_SRC, pox: false, d: 55  },
        { x: W * 0.62, y: H * 0.72, src: PFP_SRC, pox: false, d: 25  },
        { x: W * 0.50, y: H * 0.15, src: POX_SRC, pox: true,  d: 10  },
      ];
      motes.forEach(m => {
        spawnMote(rect, m.x + rand(-6,6), m.y + rand(-6,6), m.src, m.pox, m.d);
      });
    }

    let navController = null;

    function initNav() {
      const hamburger = document.getElementById('hamburger');
      const overlay = document.getElementById('nav-overlay');
      const closeBtn = document.getElementById('overlay-close');
      if (!hamburger || !overlay) return;

      // Abort old listeners before attaching new ones
      if (navController) navController.abort();
      navController = new AbortController();
      const { signal } = navController;

      const overlayLinks = overlay.querySelectorAll('.overlay-link');

      function openNav() {
        overlay.classList.add('is-open');
        overlay.setAttribute('aria-hidden', 'false');
        hamburger.classList.add('is-active');
        hamburger.setAttribute('aria-expanded', 'true');
        hamburger.setAttribute('aria-label', 'Close navigation');
        document.body.style.overflow = 'hidden';
        closeBtn.focus();
      }

      function closeNav() {
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        hamburger.classList.remove('is-active');
        hamburger.setAttribute('aria-expanded', 'false');
        hamburger.setAttribute('aria-label', 'Open navigation');
        document.body.style.overflow = '';
        hamburger.focus();
      }

      hamburger.addEventListener('pointerdown', () => burst(hamburger), { signal });
      hamburger.addEventListener('click', () => {
        if (overlay.classList.contains('is-open')) {
          closeNav();
        } else {
          openNav();
        }
      }, { signal });

      closeBtn.addEventListener('click', closeNav, { signal });

      overlayLinks.forEach(link => {
        link.addEventListener('click', closeNav, { signal });
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
          closeNav();
        }
      }, { signal });

      overlay.addEventListener('keydown', (e) => {
        if (!overlay.classList.contains('is-open')) return;
        if (e.key !== 'Tab') return;

        const focusable = Array.from(
          overlay.querySelectorAll('button, a[href], [tabindex]:not([tabindex="-1"])')
        ).filter(el => !el.closest('[aria-hidden="true"]'));

        const first = focusable[0];
        const last = focusable[focusable.length - 1];

        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }, { signal });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initNav);
    } else {
      initNav();
    }

    document.addEventListener('astro:page-load', initNav);
  })();
</script>
