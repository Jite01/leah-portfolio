---
// src/components/Nav.astro
// Hamburger → diagonal-bar X → fullscreen white overlay
// Beach photo dimmed at ~15% behind links
// Links: The Kickoff · Media · Collection · Connect
---

<a href="#main-content" class="skip-link">Skip to content</a>

<header class="nav-bar" id="nav-bar">
  <div class="nav-inner">
    <a href="/" class="nav-wordmark" aria-label="Leah Bluewater — home">
      <span class="nav-wordmark-stack">
        <span class="nav-wordmark-name">LEAH</span>
        <span class="nav-wordmark-handle mono-label">@leahbluewater</span>
      </span>
    </a>

    <button
      class="hamburger"
      id="hamburger"
      aria-controls="nav-overlay"
      aria-expanded="false"
      aria-label="Open navigation"
      type="button"
    >
      <span class="bar bar-1"></span>
      <span class="bar bar-2"></span>
      <span class="bar bar-3"></span>
    </button>
  </div>
</header>

<div class="nav-overlay" id="nav-overlay" aria-hidden="true">
  <div class="overlay-photo" aria-hidden="true"></div>

  <nav class="overlay-nav" aria-label="Main navigation">
    <ol class="overlay-links">
      <li class="overlay-item">
        <a href="/" class="overlay-link">
          <span class="link-text">The Kickoff</span>
        </a>
      </li>
      <li class="overlay-item">
        <a href="/media" class="overlay-link">
          <span class="link-text">Media</span>
        </a>
      </li>
      <li class="overlay-item">
        <a href="/collection" class="overlay-link">
          <span class="link-text">Collection</span>
        </a>
      </li>
      <li class="overlay-item">
        <a href="/connect" class="overlay-link">
          <span class="link-text">Connect</span>
        </a>
      </li>
    </ol>

    <div class="overlay-footer">
      <span class="mono-label overlay-footnote">@leahbluewater · Doginal Dogs</span>
    </div>
  </nav>
</div>

<style>
  .nav-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    height: var(--nav-h, 80px);
    background: var(--clr-bg);
    border-bottom: 1px solid var(--clr-border);
  }

  .nav-inner {
    max-width: var(--max-w-content);
    margin-inline: auto;
    padding-inline: var(--page-px);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .nav-wordmark {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .nav-wordmark-stack {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    line-height: 1;
  }

  .nav-wordmark-name {
    font-family: var(--font-heading);
    font-weight: var(--fw-extrabold);
    font-size: 1rem;
    letter-spacing: -0.02em;
    color: var(--clr-text);
    transform: translateY(1px);
  }

  .nav-wordmark-handle {
    display: inline-block;
    color: var(--clr-text-faint);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    white-space: nowrap;
    overflow: hidden;
    width: 0;
    border-right: 1px solid var(--clr-accent);
    animation:
      typing 1.8s steps(16, end) 180ms forwards,
      caret 900ms step-end infinite;
  }

  .hamburger {
    width: 36px;
    height: 36px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    gap: 5px;
    padding: 4px;
    position: relative;
    z-index: calc(var(--z-overlay) + 10);
    transition: opacity var(--dur-base) var(--ease-out);
  }

  .hamburger .bar {
    display: block;
    height: 1.5px;
    background: var(--clr-text);
    border-radius: 1px;
    transform-origin: center;
    transition:
      width     var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out),
      opacity   var(--dur-base) var(--ease-out);
  }

  .hamburger .bar-1 { width: 24px; }
  .hamburger .bar-2 { width: 16px; }
  .hamburger .bar-3 { width: 20px; }

  .hamburger.is-open .bar-1 {
    width: 24px;
    transform: translateY(6.5px) rotate(45deg);
  }

  .hamburger.is-open .bar-2 {
    opacity: 0;
    transform: translateX(8px);
  }

  .hamburger.is-open .bar-3 {
    width: 24px;
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-overlay);
    background: var(--clr-bg);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding-inline: var(--page-px);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-slow) var(--ease-out);
  }

  .nav-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .overlay-photo {
    position: absolute;
    inset: 0;
    background-image: url('/hero.jpg');
    background-size: cover;
    background-position: center 30%;
    opacity: 0.15;
    pointer-events: none;
  }

  .overlay-nav {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--max-w-content);
    margin-inline: auto;
  }

  .overlay-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .overlay-item {
    border-top: 1px solid var(--clr-border);
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity   var(--dur-slow) var(--ease-out),
      transform var(--dur-slow) var(--ease-out);
  }

  .overlay-item:last-child {
    border-bottom: 1px solid var(--clr-border);
  }

  .overlay-item:nth-child(1) { transition-delay: 60ms; }
  .overlay-item:nth-child(2) { transition-delay: 120ms; }
  .overlay-item:nth-child(3) { transition-delay: 180ms; }
  .overlay-item:nth-child(4) { transition-delay: 240ms; }

  .nav-overlay.is-open .overlay-item {
    opacity: 1;
    transform: translateY(0);
  }

  .overlay-link {
    display: flex;
    align-items: baseline;
    gap: var(--space-5);
    padding-block: clamp(1rem, 3vw, 1.75rem);
    text-decoration: none;
    color: var(--clr-text);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .overlay-link:hover {
    color: var(--clr-accent);
  }

  .link-text {
    font-family: var(--font-heading);
    font-weight: var(--fw-extrabold);
    font-size: clamp(2rem, 7vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .overlay-footer {
    margin-top: var(--space-7);
    opacity: 0;
    transition: opacity var(--dur-slow) var(--ease-out) 300ms;
  }

  .nav-overlay.is-open .overlay-footer {
    opacity: 1;
  }

  .overlay-footnote {
    color: var(--clr-text-faint);
  }

  @keyframes typing {
    from { width: 0; }
    to { width: 16ch; }
  }

  @keyframes caret {
    0%, 100% { border-color: var(--clr-accent); }
    50% { border-color: transparent; }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-overlay,
    .overlay-item,
    .overlay-footer,
    .hamburger .bar,
    .nav-wordmark-handle {
      transition: none !important;
      animation: none !important;
    }

    .nav-wordmark-handle {
      width: auto;
      border-right: 0;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const overlay = document.getElementById('nav-overlay');
  const overlayLinks = overlay ? overlay.querySelectorAll('.overlay-link') : [];

  if (hamburger && overlay) {
    function openNav() {
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      hamburger.classList.add('is-open');
      hamburger.setAttribute('aria-expanded', 'true');
      hamburger.setAttribute('aria-label', 'Close navigation');
      document.body.style.overflow = 'hidden';
      const firstLink = overlay.querySelector('.overlay-link');
      if (firstLink) firstLink.focus();
    }

    function closeNav() {
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      hamburger.classList.remove('is-open');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.setAttribute('aria-label', 'Open navigation');
      document.body.style.overflow = '';
      hamburger.focus();
    }

    hamburger.addEventListener('click', () => {
      if (overlay.classList.contains('is-open')) {
        closeNav();
      } else {
        openNav();
      }
    });

    overlayLinks.forEach((link) => {
      link.addEventListener('click', closeNav);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
        closeNav();
      }
    });

    overlay.addEventListener('keydown', (e) => {
      if (!overlay.classList.contains('is-open')) return;
      if (e.key !== 'Tab') return;

      const focusable = Array.from(
        overlay.querySelectorAll('button, a[href], [tabindex]:not([tabindex="-1"])')
      ).filter((el) => !el.closest('[aria-hidden="true"]'));

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (!first || !last) return;

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });
  }
</script>
