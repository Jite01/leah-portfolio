---
---

<a href="#main-content" class="skip-link">Skip to content</a>

<header class="nav-bar" id="nav-bar">
  <div class="nav-inner">
    <a href="/" class="nav-wordmark" aria-label="Leah Bluewater — home">
      <span class="nav-wordmark-name">LEAH</span>
      <span class="nav-wordmark-handle mono-label">@leahbluewater</span>
    </a>

    <button
      class="hamburger"
      id="hamburger"
      aria-controls="nav-overlay"
      aria-expanded="false"
      aria-label="Open navigation"
    >
      <span class="bar bar-1"></span>
      <span class="bar bar-2"></span>
      <span class="bar bar-3"></span>
    </button>
  </div>
</header>

<div class="nav-overlay" id="nav-overlay" aria-hidden="true">
  <div class="overlay-photo" aria-hidden="true"></div>

  <button
    class="overlay-close"
    id="overlay-close"
    aria-label="Close navigation"
  >
    <span class="bar bar-1"></span>
    <span class="bar bar-2"></span>
  </button>

  <nav class="overlay-nav" aria-label="Main navigation">
    <ol class="overlay-links">
      <li class="overlay-item">
        <a href="/" class="overlay-link">
          <span class="link-text">Kickoff</span>
        </a>
      </li>
      <li class="overlay-item">
        <a href="/media" class="overlay-link">
          <span class="link-text">Media</span>
        </a>
      </li>
      <li class="overlay-item">
        <a href="/collection" class="overlay-link">
          <span class="link-text">Collection</span>
        </a>
      </li>
      <li class="overlay-item">
        <a href="/connect" class="overlay-link">
          <span class="link-text">Connect</span>
        </a>
      </li>
    </ol>
    <div class="overlay-footer">
      <span class="mono-label" style="color: var(--clr-text-faint);">@leahbluewater · TypeMedia · Doginal Dogs</span>
    </div>
  </nav>
</div>

<style>
  .nav-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    height: 64px;
    background: var(--clr-bg);
    border-bottom: 1px solid var(--clr-border);
  }

  :root { --nav-h: 64px; }

  .nav-inner {
    max-width: var(--max-w-content);
    margin-inline: auto;
    padding-inline: var(--page-px);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-wordmark {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    text-decoration: none;
    line-height: 1;
  }

  .nav-wordmark-name {
    font-family: var(--font-heading);
    font-weight: var(--fw-extrabold);
    font-size: 1.1rem;
    letter-spacing: -0.01em;
    color: var(--clr-text);
    line-height: 1;
  }

  .nav-wordmark-handle {
    color: var(--clr-text-faint);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    line-height: 1;
    margin-top: 1px;
  }

  .hamburger {
    width: 36px;
    height: 36px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    gap: 5px;
    padding: 4px;
    position: relative;
    z-index: calc(var(--z-overlay) + 10);
    transition: opacity var(--dur-base) var(--ease-out);
    overflow: visible;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .hamburger .bar {
    display: block;
    height: 1.5px;
    background: var(--clr-text);
    border-radius: 1px;
    transform-origin: center;
    transition: width var(--dur-base) var(--ease-out),
                transform var(--dur-base) var(--ease-out),
                opacity var(--dur-base) var(--ease-out);
  }

  .hamburger .bar-1 { width: 24px; }
  .hamburger .bar-2 { width: 16px; }
  .hamburger .bar-3 { width: 20px; }

  .hamburger.is-active .bar-1 {
    transform: translateY(6.5px) rotate(45deg);
    width: 24px;
  }
  .hamburger.is-active .bar-2 {
    opacity: 0;
    width: 0;
  }
  .hamburger.is-active .bar-3 {
    transform: translateY(-6.5px) rotate(-45deg);
    width: 24px;
  }

  /* ════════════════════════════════════════════
       MOTE  — 48×48, badge ring + image face
       ════════════════════════════════════════════ */
    .mote {
      position: absolute;
      width: 48px;
      height: 48px;
      pointer-events: none;
      will-change: transform, opacity;
      animation: moteFall var(--fall-dur, 2200ms)
                 cubic-bezier(0.12, 0.9, 0.3, 1) forwards;
    }

    /* ── inner metallic ring (exact .kickoff-badge-halo) ── */
    .mote-halo {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      background: conic-gradient(
        from 0deg,
        rgba(70,  85,  100, 0.25),
        rgba(180, 198, 215, 0.80),
        rgba(235, 245, 255, 1.00),
        rgba(255, 255, 255, 1.00),
        rgba(200, 215, 228, 0.85),
        rgba(150, 168, 185, 0.60),
        rgba(100, 118, 135, 0.35),
        rgba(70,  85,  100, 0.25)
      );
      animation: moteRingSpin var(--spin-a, 2.2s) linear infinite;
    }

    /* ── outer diffuse blue halo (exact .kickoff-badge-halo--outer) ── */
    .mote-halo--outer {
      inset: -5px;
      background: conic-gradient(
        from 180deg,
        rgba(60,  80,  110, 0.00),
        rgba(100, 150, 200, 0.45),
        rgba(180, 210, 240, 0.70),
        rgba(100, 150, 200, 0.45),
        rgba(60,  80,  110, 0.00)
      );
      filter: blur(1px);
      animation: moteRingSpin var(--spin-b, 3.4s) linear infinite reverse;
    }

    /* ── face plate: image fills the dark disc ── */
    .mote-face {
      position: absolute;
      inset: 3px;
      border-radius: 50%;
      overflow: hidden;   /* clips image to circle */
      z-index: 2;
      box-shadow:
        inset 0 1px 2px rgba(255, 255, 255, 0.12),
        inset 0 -1px 2px rgba(0, 0, 0, 0.55),
        0 0 12px rgba(140, 185, 230, 0.50),
        0 0 28px rgba(60,  130, 200, 0.25);
    }

    .mote-face img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
      /* pixel art pfp stays crisp at small size */
      image-rendering: pixelated;
    }

    /* POX mote: banner is wide, so zoom in to frame the virus-O at center */
    .mote-face--pox img {
      image-rendering: auto;            /* smooth for the illustrated banner  */
      object-fit: cover;
      object-position: center center;
      /* slight zoom ensures the "O" virus glyph fills the disc */
      width: 200%;
      height: 200%;
      margin-left: -50%;
      margin-top: -50%;
    }

    /* ════════════════════════════════════════════
       KEYFRAMES
       ════════════════════════════════════════════ */
    @keyframes moteRingSpin {
      to { transform: rotate(360deg); }
    }

    @keyframes moteFall {
      0% {
        opacity: 0;
        transform: translate(0, 0) scale(0.22) rotate(0deg);
      }
      /* burst pop — slight upward kick */
      7% {
        opacity: 1;
        transform: translate(var(--dx1), var(--dy1)) scale(1.10) rotate(var(--r1));
      }
      /* mid-air, well-lit, drifting */
      68% {
        opacity: 0.90;
        transform: translate(var(--dx-mid), var(--dy-mid)) scale(0.95) rotate(var(--r-mid));
      }
      /* far below the button, fading out */
      100% {
        opacity: 0;
        transform: translate(var(--dx2), var(--dy2)) scale(0.70) rotate(var(--r2));
      }
    }

  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-overlay);
    background: var(--clr-bg);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding-inline: var(--page-px);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-slow) var(--ease-out);
  }

  .nav-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .overlay-photo {
    position: absolute;
    inset: 0;
    background-image: url('/hero.jpg');
    background-size: cover;
    background-position: center 30%;
    opacity: 0.55;
    pointer-events: none;
  }

  .overlay-close {
    position: absolute;
    top: calc((64px - 36px) / 2);
    right: var(--page-px);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
    z-index: 1;
  }

  .overlay-close .bar {
    display: block;
    position: absolute;
    width: 24px;
    height: 1.5px;
    background: var(--clr-text);
    border-radius: 1px;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .overlay-close .bar-1 { transform: rotate(45deg); }
  .overlay-close .bar-2 { transform: rotate(-45deg); }

  .overlay-nav {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--max-w-content);
    margin-inline: auto;
  }

  .overlay-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .overlay-item {
    border-top: 1px solid var(--clr-border);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity var(--dur-slow) var(--ease-out),
                transform var(--dur-slow) var(--ease-out);
  }

  .overlay-item:last-child {
    border-bottom: 1px solid var(--clr-border);
  }

  .overlay-item:nth-child(1) { transition-delay: 60ms; }
  .overlay-item:nth-child(2) { transition-delay: 120ms; }
  .overlay-item:nth-child(3) { transition-delay: 180ms; }
  .overlay-item:nth-child(4) { transition-delay: 240ms; }

  .nav-overlay.is-open .overlay-item {
    opacity: 1;
    transform: translateY(0);
  }

  .overlay-link {
    display: flex;
    align-items: baseline;
    gap: var(--space-5);
    padding-block: clamp(1rem, 3vw, 1.75rem);
    text-decoration: none;
    color: var(--clr-text);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .overlay-link:hover {
    color: var(--clr-accent);
  }

  .link-text {
    font-family: var(--font-heading);
    font-weight: var(--fw-extrabold);
    font-size: clamp(2rem, 7vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .overlay-footer {
    margin-top: var(--space-7);
    opacity: 0;
    transition: opacity var(--dur-slow) var(--ease-out) 300ms;
  }

  .nav-overlay.is-open .overlay-footer {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-overlay, .overlay-item, .overlay-footer,
    .hamburger .bar, .overlay-close .bar,
    .mote {
      transition: none !important;
      animation: none !important;
    }
  }
</style>

<script>
  (function() {
    const PFP_SRC = '/pfp.jpg';
    const POX_SRC = '/pox.jpg';

    function rand(lo, hi) { return Math.random() * (hi - lo) + lo; }
    function px(n)        { return n.toFixed(2) + 'px'; }
    function dg(n)        { return n.toFixed(1) + 'deg'; }

    function initNav() {
      const hamburger = document.getElementById('hamburger');
      const overlay   = document.getElementById('nav-overlay');
      const closeBtn  = document.getElementById('overlay-close');
      if (!hamburger || !overlay) return;

      if (hamburger._navBound) return;
      hamburger._navBound = true;

      const overlayLinks = overlay.querySelectorAll('.overlay-link');

      /**
       * Spawns one 48×48 badge-ring mote at (localX, localY) relative to the button.
       */
      function spawnMote(localX, localY, imgSrc, isPox, delayMs) {
        setTimeout(() => {

          /* ── Outer wrapper ── */
          const mote = document.createElement('div');
          mote.className = 'mote';
          mote.style.left = px(localX - 24); // centre 48px disc on spawn point
          mote.style.top  = px(localY - 24);

          /* ── Outer diffuse halo ── */
          const haloOuter = document.createElement('div');
          haloOuter.className = 'mote-halo mote-halo--outer';

          /* ── Inner metallic ring ── */
          const haloInner = document.createElement('div');
          haloInner.className = 'mote-halo';

          /* ── Face plate ── */
          const face = document.createElement('div');
          face.className = isPox
            ? 'mote-face mote-face--pox'
            : 'mote-face';

          const img = document.createElement('img');
          img.src = imgSrc;
          img.alt = '';
          img.draggable = false;
          face.appendChild(img);

          mote.append(haloOuter, haloInner, face);

          /* ── Unique spin speeds per mote ── */
          mote.style.setProperty('--spin-a', rand(1.4, 3.0).toFixed(2) + 's');
          mote.style.setProperty('--spin-b', rand(2.6, 4.8).toFixed(2) + 's');

          /* ── Trajectory ──
               dy1    : slight upward pop on burst
               dy-mid : mid-air waypoint
               dy2    : far descent                */
          mote.style.setProperty('--dx1',    px(rand(-22,  22)));
          mote.style.setProperty('--dy1',    px(rand(-28,  -6)));
          mote.style.setProperty('--dx-mid', px(rand(-70,  70)));
          mote.style.setProperty('--dy-mid', px(rand( 90, 200)));
          mote.style.setProperty('--dx2',    px(rand(-110, 110)));
          mote.style.setProperty('--dy2',    px(rand( 260, 440)));
          mote.style.setProperty('--r1',     dg(rand(-28,  28)));
          mote.style.setProperty('--r-mid',  dg(rand(-110, 110)));
          mote.style.setProperty('--r2',     dg(rand(-220, 220)));

          /* ── Duration: 1.9 s – 3.1 s ── */
          const dur = Math.round(rand(1900, 3100));
          mote.style.setProperty('--fall-dur', dur + 'ms');

          hamburger.appendChild(mote);
          setTimeout(() => mote.remove(), dur + 80);
        }, delayMs);
      }

      function burst() {
        const W = hamburger.offsetWidth;
        const H = hamburger.offsetHeight;

        /*
         * 4 motes, mapped to the three diagonal bars + one bonus.
         * 3 pfp motes  — emerge from bar-A, bar-B, bar-C
         * 1 POX mote   — bursts from top-centre (above bar-A)
         */
        const motes = [
          /* bar-A zone  */
          { x: W * 0.38, y: H * 0.28, src: PFP_SRC, pox: false, d:  0  },
          /* bar-B centre */
          { x: W * 0.50, y: H * 0.50, src: PFP_SRC, pox: false, d:  55 },
          /* bar-C zone  */
          { x: W * 0.62, y: H * 0.72, src: PFP_SRC, pox: false, d:  25 },
          /* POX — top-centre, erupts first for emphasis */
          { x: W * 0.50, y: H * 0.15, src: POX_SRC, pox: true,  d:  10 },
        ];

        motes.forEach(m => {
          spawnMote(
            m.x + rand(-6, 6),
            m.y + rand(-6, 6),
            m.src,
            m.pox,
            m.d
          );
        });
      }

      function openNav() {
        overlay.classList.add('is-open');
        overlay.setAttribute('aria-hidden', 'false');
        hamburger.classList.add('is-active');
        hamburger.setAttribute('aria-expanded', 'true');
        hamburger.setAttribute('aria-label', 'Close navigation');
        document.body.style.overflow = 'hidden';
        closeBtn.focus();
        setTimeout(burst, 1000);
      }

      function closeNav() {
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        hamburger.classList.remove('is-active');
        hamburger.setAttribute('aria-expanded', 'false');
        hamburger.setAttribute('aria-label', 'Open navigation');
        document.body.style.overflow = '';
        hamburger.focus();
      }

      hamburger.addEventListener('click', () => {
        if (overlay.classList.contains('is-open')) {
          closeNav();
        } else {
          openNav();
        }
      });

      closeBtn.addEventListener('click', closeNav);

      overlayLinks.forEach(link => {
        link.addEventListener('click', closeNav);
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
          closeNav();
        }
      });

      overlay.addEventListener('keydown', (e) => {
        if (!overlay.classList.contains('is-open')) return;
        if (e.key !== 'Tab') return;

        const focusable = Array.from(
          overlay.querySelectorAll('button, a[href], [tabindex]:not([tabindex="-1"])')
        ).filter(el => !el.closest('[aria-hidden="true"]'));

        const first = focusable[0];
        const last  = focusable[focusable.length - 1];

        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initNav);
    } else {
      initNav();
    }

    document.addEventListener('astro:page-load', initNav);
  })();
</script>
